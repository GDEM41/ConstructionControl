<Window x:Class="ConstructionControl.ObjectSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConstructionControl"
        Title="Настройки объекта"
        Width="780"
        Height="860"
        MinWidth="700"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource AppBgBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="TextTrimming" Value="None"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource SurfaceBrush}"
            CornerRadius="10"
            Padding="16"
            Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="Параметры объекта"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,14"/>

                    <Border x:Name="CreateAsNewBorder"
                            Visibility="Collapsed"
                            Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,12">
                        <CheckBox x:Name="CreateAsNewCheck"
                                  Content="Создать новый объект (не перезаписывать текущий)"
                                  Foreground="{StaticResource TextBrush}"/>
                    </Border>

                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Название объекта" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="NameBox" Height="40" Padding="12,8"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,10">
                            <TextBlock Text="Полное название объекта" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="FullObjectNameBox" Height="40" Padding="12,8"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Количество блоков" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="BlocksBox" Height="40" Padding="12,8" TextChanged="BlocksBox_TextChanged"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,10">
                            <CheckBox x:Name="BasementCheck" Content="Есть подвал" VerticalAlignment="Center" Margin="0,20,0,0"/>
                        </StackPanel>
                    </UniformGrid>

                    <CheckBox x:Name="SameFloorsCheck"
                              Content="Одинаковое количество этажей во всех блоках"
                              Margin="0,0,0,10"
                              Foreground="{StaticResource TextBrush}"
                              Checked="SameFloorsChanged"
                              Unchecked="SameFloorsChanged"/>

                    <StackPanel x:Name="SameFloorsPanel" Margin="0,0,0,10">
                        <TextBlock Text="Этажей в блоке" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="FloorsPerBlockBox" Height="40" Width="220" HorizontalAlignment="Left" Padding="12,8"/>
                    </StackPanel>

                    <DataGrid x:Name="FloorsByBlockGrid"
                              local:DataGridSizingHelper.EnableSmartSizing="False"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Visibility="Collapsed"
                              Height="160"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Блок" Binding="{Binding Block}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Этажей" Binding="{Binding Floors, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="Оси по блокам" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,4,0,6"/>
                    <DataGrid x:Name="BlockAxesGrid"
                              local:DataGridSizingHelper.EnableSmartSizing="False"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Height="170"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Блок" Binding="{Binding Block}" IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Оси (пример: 1-11/Л-ГГ)" Binding="{Binding Axes, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="Ответственные лица" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,2,0,8"/>
                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Представитель генподрядной организации" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="GeneralContractorRepresentativeBox" Height="40" Padding="12,8"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,10">
                            <TextBlock Text="Представитель технического надзора" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TechnicalSupervisorRepresentativeBox" Height="40" Padding="12,8"/>
                        </StackPanel>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,10">
                        <StackPanel Margin="0,0,10,10">
                            <TextBlock Text="Представитель проектной организации" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ProjectOrganizationRepresentativeBox" Height="40" Padding="12,8"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,10">
                            <TextBlock Text="Наименование проектной документации" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBox x:Name="ProjectDocumentationNameBox" Height="40" Padding="12,8"/>
                        </StackPanel>
                    </UniformGrid>

                    <TextBlock Text="Мастера" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,2,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Количество мастеров" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                        <ComboBox x:Name="MasterCountComboBox" Width="90" Height="40" SelectionChanged="MasterCountComboBox_SelectionChanged"/>
                    </StackPanel>
                    <DataGrid x:Name="MastersGrid"
                              local:DataGridSizingHelper.EnableSmartSizing="False"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Height="160"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="ФИО мастера" Binding="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="Прорабы" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,2,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Количество прорабов" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                        <ComboBox x:Name="ForemanCountComboBox" Width="90" Height="40" SelectionChanged="ForemanCountComboBox_SelectionChanged"/>
                        <TextBlock Text="Ответственный" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="18,0,10,0"/>
                        <ComboBox x:Name="ResponsibleForemanComboBox" Width="280" Height="40" DisplayMemberPath="FullName"/>
                    </StackPanel>
                    <DataGrid x:Name="ForemenGrid"
                              local:DataGridSizingHelper.EnableSmartSizing="False"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Height="170"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="ФИО прораба" Binding="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="ФИО начальника участка" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <TextBox x:Name="SiteManagerNameBox" Height="40" Padding="12,8"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="Отмена"
                        Width="110"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="Cancel_Click"/>
                <Button Content="Сохранить"
                        Width="130"
                        Height="34"
                        Click="Ok_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
