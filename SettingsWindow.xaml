<Window x:Class="ConstructionControl.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="840"
        Height="620"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource AppBgBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <StackPanel>
                <TextBlock Text="Настройки интерфейса"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Параметры сохраняются внутри объекта и экспортируются вместе с ним."
                           Margin="0,8,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <CheckBox x:Name="DisableTreeCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Отключить дерево материалов" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Полностью скрывает дерево материалов и область его раскрытия."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <CheckBox x:Name="PinTreeCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Закреплять дерево по умолчанию" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Если дерево не отключено, оно будет открыто сразу после запуска объекта."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <CheckBox x:Name="ReminderPopupCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Показывать уведомления" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Напоминания по ОТ, табелю и осмотрам будут видны на любой вкладке."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <CheckBox x:Name="SafeStartupModeCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Безопасный старт (минимальная нагрузка)" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Отключает предзагрузку тяжелых предпросмотров и включает загрузку вкладок по требованию."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <CheckBox x:Name="AutoFitCurrentTabColumnsCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Подгонять колонки текущей вкладки автоматически" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="При открытии вкладки ширина колонок таблицы пересчитывается под содержимое."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,2,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Плотность интерфейса"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <ComboBox x:Name="DensityModeBox"
                                  Grid.Column="1"
                                  Height="40"
                                  VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Стандартный"/>
                            <ComboBoxItem Content="Компактный"/>
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,2,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Роль доступа"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <ComboBox x:Name="AccessRoleBox"
                                  Grid.Column="1"
                                  Height="40"
                                  VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Просмотр" Tag="view"/>
                            <ComboBoxItem Content="Редактирование" Tag="edit"/>
                            <ComboBoxItem Content="Критические операции" Tag="critical"/>
                        </ComboBox>
                    </Grid>

                    <CheckBox x:Name="RequireCodeForCriticalOperationsCheckBox"
                              FontWeight="SemiBold"
                              Margin="0,0,0,10">
                        <TextBlock Text="Подтверждать опасные операции кодом" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Для очистки, массового удаления и восстановления потребуется ввести случайный код."
                               Margin="28,0,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,2,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Время отложенных уведомлений (мин)"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBox x:Name="ReminderSnoozeMinutesBox"
                                 Grid.Column="1"
                                 Height="40"
                                 Padding="8,2"
                                 FontSize="14"
                                 MaxLength="3"
                                 TextAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                  PreviewTextInput="NumericTextBox_PreviewTextInput"
                                  Text="15"/>
                    </Grid>

                    <Grid Margin="0,2,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Автосохранение каждые (мин)"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBox x:Name="AutoSaveIntervalMinutesBox"
                                 Grid.Column="1"
                                 Height="40"
                                 Padding="8,2"
                                 FontSize="14"
                                 MaxLength="3"
                                 TextAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 PreviewTextInput="NumericTextBox_PreviewTextInput"
                                  Text="5"/>
                    </Grid>

                      <Grid Margin="0,2,0,12">
                          <Grid.RowDefinitions>
                              <RowDefinition Height="Auto"/>
                              <RowDefinition Height="Auto"/>
                          </Grid.RowDefinitions>
                        <TextBlock Text="Папка данных (кэш, автосохранение, служебные файлы)"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   TextWrapping="Wrap"/>
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DataRootPathBox"
                                     Height="40"
                                     Padding="10,2"
                                     VerticalContentAlignment="Center"
                                     Tag="Путь к папке данных"/>
                              <Button Grid.Column="1"
                                      Margin="8,0,0,0"
                                      MinWidth="110"
                                      Style="{StaticResource AppSecondaryButton}"
                                      Click="BrowseDataRootButton_Click">Обзор...</Button>
                          </Grid>
                      </Grid>

                      <Separator Margin="0,4,0,10"/>

                      <TextBlock Text="Обновления"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource TextBrush}"
                                 Margin="0,0,0,8"/>

                      <CheckBox x:Name="CheckUpdatesOnStartCheckBox" FontWeight="SemiBold">
                          <TextBlock Text="Проверять обновления при запуске" TextWrapping="Wrap"/>
                      </CheckBox>

                      <Grid Margin="0,6,0,12">
                          <Grid.RowDefinitions>
                              <RowDefinition Height="Auto"/>
                              <RowDefinition Height="Auto"/>
                          </Grid.RowDefinitions>
                          <TextBlock Text="URL файла обновлений (JSON)"
                                     VerticalAlignment="Center"
                                     FontWeight="SemiBold"
                                     Foreground="{StaticResource TextBrush}"
                                     TextWrapping="Wrap"/>
                          <TextBox x:Name="UpdateFeedUrlBox"
                                   Grid.Row="1"
                                   Height="40"
                                   Margin="0,8,0,0"
                                   Padding="10,2"
                                   VerticalContentAlignment="Center"
                                   Tag="https://example.com/masterpro/latest.json"/>
                      </Grid>

                      <Separator Margin="0,4,0,10"/>

                    <TextBlock Text="Уведомления по сводке"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,8"/>

                    <CheckBox x:Name="SummaryReminderOverageCheckBox"
                              FontWeight="SemiBold"
                              IsChecked="True">
                        <TextBlock Text="Показывать переход (пришло больше, чем нужно)" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox x:Name="SummaryReminderDeficitCheckBox"
                              FontWeight="SemiBold"
                              Margin="0,6,0,0">
                        <TextBlock Text="Показывать недоход (пришло меньше, чем нужно)" TextWrapping="Wrap"/>
                    </CheckBox>
                    <CheckBox x:Name="SummaryReminderMainOnlyCheckBox"
                              FontWeight="SemiBold"
                              Margin="0,6,0,8"
                              IsChecked="True">
                        <TextBlock Text="Только для основных материалов" TextWrapping="Wrap"/>
                    </CheckBox>

                    <CheckBox x:Name="HideReminderDetailsCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Скрывать содержимое уведомлений (оставлять только индикатор)" TextWrapping="Wrap"/>
                    </CheckBox>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Отмена"
                    Width="120"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Style="{StaticResource AppSecondaryButton}"/>
            <Button Content="Сохранить"
                    Width="140"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>

