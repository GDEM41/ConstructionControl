<Window x:Class="ConstructionControl.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="560"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F7FB">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <StackPanel>
                <TextBlock Text="Настройки интерфейса"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"/>
                <TextBlock Text="Параметры сохраняются внутри объекта и экспортируются вместе с ним."
                           Margin="0,8,0,0"
                           Foreground="#64748B"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <StackPanel>
                <CheckBox x:Name="DisableTreeCheckBox"
                          Content="Отключить дерево материалов"
                          FontWeight="SemiBold"/>
                <TextBlock Text="Полностью скрывает дерево материалов и область его раскрытия."
                           Margin="28,4,0,12"
                           Foreground="#64748B"
                           TextWrapping="Wrap"/>

                <CheckBox x:Name="PinTreeCheckBox"
                          Content="Закреплять дерево по умолчанию"
                          FontWeight="SemiBold"/>
                <TextBlock Text="Если дерево не отключено, оно будет открыто сразу после запуска объекта."
                           Margin="28,4,0,12"
                           Foreground="#64748B"
                           TextWrapping="Wrap"/>

                <CheckBox x:Name="ReminderPopupCheckBox"
                          Content="Показывать уведомления"
                          FontWeight="SemiBold"/>
                <TextBlock Text="Напоминания по ОТ, табелю и осмотрам будут видны на любой вкладке."
                           Margin="28,4,0,12"
                           Foreground="#64748B"
                           TextWrapping="Wrap"/>

                <Grid Margin="0,2,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Время отложенных уведомлений (мин)"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"/>
                    <TextBox x:Name="ReminderSnoozeMinutesBox"
                             Grid.Column="1"
                             Height="34"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             Text="15"/>
                </Grid>

                <CheckBox x:Name="HideReminderDetailsCheckBox"
                          Content="Скрывать содержимое уведомлений (оставлять только индикатор)"
                          FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Отмена"
                    Width="120"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Style="{StaticResource AppSecondaryButton}"/>
            <Button Content="Сохранить"
                    Width="140"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>

