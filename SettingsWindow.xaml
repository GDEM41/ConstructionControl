<Window x:Class="ConstructionControl.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource AppBgBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <StackPanel>
                <TextBlock Text="Настройки интерфейса"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Параметры сохраняются внутри объекта и экспортируются вместе с ним."
                           Margin="0,8,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <CheckBox x:Name="DisableTreeCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Отключить дерево материалов" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Полностью скрывает дерево материалов и область его раскрытия."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <CheckBox x:Name="PinTreeCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Закреплять дерево по умолчанию" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Если дерево не отключено, оно будет открыто сразу после запуска объекта."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <CheckBox x:Name="ReminderPopupCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Показывать уведомления" TextWrapping="Wrap"/>
                    </CheckBox>
                    <TextBlock Text="Напоминания по ОТ, табелю и осмотрам будут видны на любой вкладке."
                               Margin="28,4,0,12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,2,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Время отложенных уведомлений (мин)"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBox x:Name="ReminderSnoozeMinutesBox"
                                 Grid.Column="1"
                                 Height="40"
                                 Padding="8,2"
                                 FontSize="14"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Text="15"/>
                    </Grid>

                    <Grid Margin="0,2,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Автосохранение каждые (мин)"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBox x:Name="AutoSaveIntervalMinutesBox"
                                 Grid.Column="1"
                                 Height="40"
                                 Padding="8,2"
                                 FontSize="14"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Text="5"/>
                    </Grid>

                    <CheckBox x:Name="HideReminderDetailsCheckBox" FontWeight="SemiBold">
                        <TextBlock Text="Скрывать содержимое уведомлений (оставлять только индикатор)" TextWrapping="Wrap"/>
                    </CheckBox>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Отмена"
                    Width="120"
                    Margin="0,0,10,0"
                    IsCancel="True"
                    Style="{StaticResource AppSecondaryButton}"/>
            <Button Content="Сохранить"
                    Width="140"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>

