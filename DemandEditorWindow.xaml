<Window x:Class="ConstructionControl.DemandEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Потребность по этажам"
        Height="700"
        Width="1250"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">

    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- верхняя панель -->
            <RowDefinition Height="*"/>
            <!-- таблица / вкладки -->
            <RowDefinition Height="Auto"/>
            <!-- кнопки -->
        </Grid.RowDefinitions>

        <!-- ===== Верхняя панель ===== -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <TextBlock Text="Потребность по этажам. Вкладка = тип. Навигация по ячейкам: стрелки клавиатуры."
                       Foreground="#334155"/>
        </Border>

        <!-- ===== Вкладки (растягиваются) ===== -->
        <TabControl x:Name="TypeTabs"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"/>

        <!-- ===== Нижняя фиксированная панель ===== -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10"
                Margin="0,10,0,0">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Отмена"
                        Width="120"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>

                <Button Content="Сохранить"
                        Width="140"
                        Height="36"
                        Background="#2563EB"
                        Foreground="White"
                        BorderBrush="#1D4ED8"
                        Click="Save_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>