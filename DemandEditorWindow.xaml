<Window x:Class="ConstructionControl.DemandEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Потребность по отметкам"
        Height="700"
        Width="1250"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SurfaceAltBrush}">
    <Window.Resources>
        <Style x:Key="DemandDialogButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.84"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- верхняя панель -->
            <RowDefinition Height="*"/>
            <!-- таблица / вкладки -->
            <RowDefinition Height="Auto"/>
            <!-- кнопки -->
        </Grid.RowDefinitions>

        <!-- ===== Верхняя панель ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <TextBlock Text="Потребность по отметкам. Вкладка = тип. Навигация по ячейкам: стрелки клавиатуры."
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>

        <!-- ===== Вкладки (растягиваются) ===== -->
        <TabControl x:Name="TypeTabs"
                    Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"/>

        <!-- ===== Нижняя фиксированная панель ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10"
                Margin="0,10,0,0">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Отмена"
                        Style="{StaticResource DemandDialogButton}"
                        Margin="0,0,8,0"
                                                Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource StrokeBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        Click="Cancel_Click"/>

                <Button Content="Сохранить"
                        Style="{StaticResource DemandDialogButton}"
                        MinWidth="140"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource PrimaryBrushPressed}"
                        Click="Save_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
