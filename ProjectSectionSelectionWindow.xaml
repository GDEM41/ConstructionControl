<Window x:Class="ConstructionControl.ProjectSectionSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор разделов"
        Width="760"
        Height="700"
        MinWidth="700"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBgBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="DialogTitleText"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock x:Name="DialogSubtitleText"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <WrapPanel Grid.Row="1"
                   Margin="0,16,0,0">
            <Button x:Name="SelectAllButton"
                    Content="Выбрать все"
                    Style="{StaticResource SecondaryButton}"
                    Click="SelectAllButton_Click"/>
            <Button x:Name="SelectNoneButton"
                    Content="Снять все"
                    Style="{StaticResource SecondaryButton}"
                    Click="SelectNoneButton_Click"/>
            <Button x:Name="DataOnlyButton"
                    Content="Только данные"
                    Style="{StaticResource SecondaryButton}"
                    Click="DataOnlyButton_Click"/>
            <Button x:Name="DataWithPdfButton"
                    Content="Данные + ПДФ"
                    Style="{StaticResource SecondaryButton}"
                    Click="DataWithPdfButton_Click"/>
            <Button x:Name="DataWithPdfEstimateButton"
                    Content="Данные + ПДФ + сметы"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0"
                    Click="DataWithPdfEstimateButton_Click"/>
        </WrapPanel>

        <Border Grid.Row="2"
                Margin="0,14,0,14"
                Padding="12"
                Background="{DynamicResource SelectedBrush}"
                BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <TextBlock x:Name="DialogHintText"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextBrush}"/>
        </Border>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SectionsHost"/>
        </ScrollViewer>

        <StackPanel Grid.Row="4"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Отмена"
                    MinWidth="120"
                    IsCancel="True"
                    Style="{StaticResource SecondaryButton}"/>
            <Button x:Name="ConfirmButton"
                    MinWidth="150"
                    Margin="8,0,0,0"
                    IsDefault="True"
                    Style="{StaticResource PrimaryButton}"
                    Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
