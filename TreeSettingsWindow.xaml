<Window x:Class="ConstructionControl.TreeSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="База материалов"
        Height="620"
        Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F6F7FB">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="12" Padding="14" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="База материалов"
                           FontWeight="SemiBold"
                           FontSize="18"
                           Foreground="#111827"/>
                <TextBlock Text="Добавляйте категории, типы, подтипы и материалы. Здесь хранится единая база для дерева и выпадающих списков в приходе."
                           Foreground="#475569"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
               Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10"
                Margin="0,10,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                <Button Content="+ Добавить запись"
                        Click="AddEntry_Click"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Background="#2563EB"
                        Foreground="White"
                        BorderBrush="#1D4ED8"/>
                <Button Content="− Удалить запись"
                        Click="RemoveEntry_Click"
                        Margin="0,0,14,0"
                        Padding="12,6"/>
                <Button Content="Переименовать тип для всех"
                        Click="RenameTypeForAll_Click"
                        Margin="0,0,10,0"
                        Padding="12,6"/>
                <Button Content="Применить разбиение к другим"
                        Click="ApplySplitToOthers_Click"
                                                Margin="0,0,8,0"
                        Padding="12,6"/>
                <Button Content="Применить подтип к материалам"
                        Click="ApplySubTypeToOthers_Click"
                        Margin="0,0,14,0"
                        Padding="12,6"/>
                
                <TextBlock Text="Уровни разбиения:"
                           VerticalAlignment="Center"
                           Foreground="#334155"
                           Margin="0,0,8,0"/>
                <Button Content="+ Уровень"
                        Click="AddLevelColumn_Click"
                        Margin="0,0,6,0"
                        Padding="10,4"/>
                <Button Content="− Уровень"
                        Click="RemoveLevelColumn_Click"
                        Padding="10,4"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="RulesGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F8FAFC"
                  RowBackground="White"
                  BorderBrush="#CBD5E1"
                  BorderThickness="1"
                   FrozenColumnCount="7"
                  CellEditEnding="RulesGrid_CellEditEnding">
            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="#EEF2FF" Padding="6" Margin="0,4,0,0" CornerRadius="4">
                                <TextBlock Text="{Binding Name, StringFormat=Категория: {0}}" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="#E0F2FE" Padding="6" Margin="12,2,0,0" CornerRadius="4">
                                <TextBlock Text="{Binding Name, StringFormat=Тип: {0}}" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="#ECFEFF" Padding="6" Margin="24,2,0,0" CornerRadius="4">
                                <TextBlock Text="{Binding Name, StringFormat=Подтип: {0}}" FontWeight="SemiBold"/>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Категория" Binding="{Binding EditableCategoryName, UpdateSourceTrigger=PropertyChanged}" Width="1*"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding EditableTypeName, UpdateSourceTrigger=PropertyChanged}" Width="1.1*"/>
                <DataGridTextColumn Header="Подтип" Binding="{Binding EditableSubTypeName, UpdateSourceTrigger=PropertyChanged}" Width="1.1*"/>
                <DataGridTextColumn x:Name="CatalogLevel4Column" Header="Подподтип" Binding="{Binding EditableLevel4Name, UpdateSourceTrigger=PropertyChanged}" Width="1.1*" Visibility="Collapsed"/>
                <DataGridTextColumn x:Name="CatalogLevel5Column" Header="Подподподтип" Binding="{Binding EditableLevel5Name, UpdateSourceTrigger=PropertyChanged}" Width="1.1*" Visibility="Visible"/>
                <DataGridTextColumn x:Name="CatalogLevel6Column" Header="Уровень 6" Binding="{Binding EditableLevel6Name, UpdateSourceTrigger=PropertyChanged}" Width="1.1*" Visibility="Collapsed"/>
                <DataGridTextColumn Header="Материал" Binding="{Binding EditableMaterialName, UpdateSourceTrigger=PropertyChanged}" Width="1.5*"/>
                <DataGridTextColumn Header="Уровень 1" Binding="{Binding Segment1, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Уровень 2" Binding="{Binding Segment2, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Уровень 3" Binding="{Binding Segment3, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Уровень 4" Binding="{Binding Segment4, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Уровень 5" Binding="{Binding Segment5, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="Уровень 6" Binding="{Binding Segment6, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn x:Name="LevelColumn7" Header="Уровень 7" Binding="{Binding Segment7, UpdateSourceTrigger=PropertyChanged}" Width="*" Visibility="Collapsed"/>
                <DataGridTextColumn x:Name="LevelColumn8" Header="Уровень 8" Binding="{Binding Segment8, UpdateSourceTrigger=PropertyChanged}" Width="*" Visibility="Collapsed"/>
                <DataGridTextColumn x:Name="LevelColumn9" Header="Уровень 9" Binding="{Binding Segment9, UpdateSourceTrigger=PropertyChanged}" Width="*" Visibility="Collapsed"/>
                <DataGridTextColumn x:Name="LevelColumn10" Header="Уровень 10" Binding="{Binding Segment10, UpdateSourceTrigger=PropertyChanged}" Width="*" Visibility="Collapsed"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Отмена" Width="120" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Сохранить" Width="120" IsDefault="True" Click="Save_Click" Background="#2563EB" Foreground="White" BorderBrush="#1D4ED8"/>
        </StackPanel>
    </Grid>
</Window>