                    <Button Content="⌘"
                            Width="42"
                            Height="34"
                            Margin="8,0,0,0"
                            ToolTip="Командная палитра"
                            Click="OpenCommandPalette_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1,1,0,0"
                Padding="10,6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Объект:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarObjectText" Margin="6,0,16,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Не создан"/>
                    <TextBlock Text="Файл:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarFileText" Margin="6,0,16,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="—"/>
                    <TextBlock Text="Автосохранение:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarAutoSaveText" Margin="6,0,16,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="5 мин"/>
                    <TextBlock Text="Доступ:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarRoleText" Margin="6,0,16,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Полный"/>
                    <TextBlock Text="Блокировка:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarLockText" Margin="6,0,16,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Вкл"/>
                    <TextBlock Text="Сохранение:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarLastSaveText" Margin="6,0,16,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Нет данных"/>
                    <TextBlock Text="Операция:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarOperationText" Margin="6,0,16,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Готово"/>
                    <TextBlock Text="Фон:" FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusBarProcessingText" Margin="6,0,0,0" Foreground="{DynamicResource TextSecondaryBrush}" Text="Ожидание"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ================= ОСНОВНАЯ ОБЛАСТЬ ================= -->
        <Grid Margin="10">

            <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="TreeHoverColumn" Width="28"/>
                    <ColumnDefinition x:Name="TreeColumn" Width="260"/>
                    <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
                <Border x:Name="TreeHoverStrip"
                    Grid.Column="0"
                    Background="{DynamicResource SelectedBrush}"
                    BorderBrush="{DynamicResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,4,0"
                    MouseEnter="TreeHoverZone_MouseEnter">
                    <Grid>
                        <TextBlock Text="Дерево материалов"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- ===== ДЕРЕВО ===== -->
                <Border x:Name="TreePanelBorder"
                    Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="6"
                    BorderBrush="{DynamicResource StrokeBrush}"
                    BorderThickness="1"
                    MouseEnter="TreePanel_MouseEnter"
                    MouseLeave="TreePanel_MouseLeave">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
