                                <Button Style="{StaticResource PrimaryButton}"
                    Click="ExportToExcel_Click">
                                    ⬇ Экспорт
                                </Button>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="JvkHeaderBorder"
