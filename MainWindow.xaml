                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="название"
                                                           FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="стб"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="3"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="ед.изм"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="4"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="кол-во"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="5"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="поставщик"
                                                        FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="6"
                                                Padding="6,4">
                                            <TextBlock Text="паспорт"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto"
                                              Margin="0,4,0,0">
                                    <StackPanel x:Name="JvkPanel"/>
                                </ScrollViewer>
                            </Grid>


                        </Grid>
                        <!-- ← ВАЖНО -->
                    </TabItem>



                    <TabItem x:Name="ArrivalTab" Header="Приход">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170*"/>
                                <ColumnDefinition Width="769*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ====== КНОПКА ДОБАВИТЬ ПРИХОД ====== -->
                            <!-- ====== КНОПКИ ПРИХОДА ====== -->
                            <StackPanel Orientation="Horizontal"
    VerticalAlignment="Top"
    HorizontalAlignment="Right"
    Panel.ZIndex="1" Grid.Column="1">

                                <!-- 🔍 Локальный поиск -->
                                <TextBox x:Name="ArrivalSearchBox"
        Width="240"
        Height="32"
        Tag="Поиск по наименованию или ТТН"
        VerticalContentAlignment="Center"
        FontSize="13"
        Margin="0,0,10,0"
        ToolTip="Поиск: наименование / ТТН"
        TextChanged="ArrivalSearchBox_TextChanged"/>

                                <!-- Кнопка фильтры -->
                                <Button x:Name="ArrivalFilterButton"
        Content="Фильтры"
        Width="130"
        Height="34"
        Margin="0,0,10,0"
        Click="ArrivalFilterButton_Click"/>

                                <Button x:Name="ArrivalLegacyViewButton"
        Content="Таблица"
        Width="120"
        Height="34"
        Margin="0,0,10,0"
        Click="ArrivalLegacyViewButton_Click"/>

                                <Button x:Name="ArrivalMatrixViewButton"
        Content="Матрица"
        Width="120"
        Height="34"
        Margin="0,0,10,0"
        Click="ArrivalMatrixViewButton_Click"/>

                                <Button Style="{StaticResource PrimaryButton}"
        Margin="0,0,10,0"
        Click="ExportArrival_Click">
                                    ⬇ Экспорт
                                </Button>


                                <!-- Кнопка добавления -->
                                <Button x:Name="ShowArrivalButton"
        Content="➕ Добавить приход"
        Width="200"
        Height="34"
        Click="ShowArrivalButton_Click"/>
                            </StackPanel>



                            <Border Grid.ColumnSpan="2"
                                    Margin="0,50,0,0"
                                    Background="White"
                                    BorderBrush="#D6DEE8"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <Grid>
                                    <ScrollViewer x:Name="ArrivalMatrixScrollViewer"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Grid x:Name="ArrivalMatrixHost"/>
                                    </ScrollViewer>

                                    <DataGrid x:Name="ArrivalLegacyGrid"
                                              Visibility="Collapsed"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserResizeColumns="True"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              GridLinesVisibility="All"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              BorderThickness="0"
                                              RowBackground="White"
                                              AlternatingRowBackground="#F8FAFC"
                                              VerticalGridLinesBrush="#D4DCE8"
                                              HorizontalGridLinesBrush="#D4DCE8"
                                              CellEditEnding="ArrivalLegacyGrid_CellEditEnding"
                                              RowEditEnding="ArrivalLegacyGrid_RowEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Дата"
                                                                Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                                                Width="95"/>
                                            <DataGridTextColumn Header="Категория"
                                                                Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="110"/>
                                            <DataGridTextColumn Header="Тип"
                                                                Binding="{Binding MaterialGroup, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="150"/>
                                            <DataGridTextColumn Header="Наименование"
                                                                Binding="{Binding MaterialName, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="240"/>
                                            <DataGridTextColumn Header="Количество"
                                                                Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="95"/>
                                            <DataGridTextColumn Header="Ед."
                                                                Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="70"/>
                                            <DataGridTextColumn Header="Паспорт"
                                                                Binding="{Binding Passport, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="130"/>
                                            <DataGridTextColumn Header="СТБ"
                                                                Binding="{Binding Stb, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="90"/>
                                            <DataGridTextColumn Header="Поставщик"
                                                                Binding="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="170"/>
                                            <DataGridTextColumn Header="ТТН"
                                                                Binding="{Binding Ttn, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="140"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- ====== ОВЕРЛЕЙ ФИЛЬТРОВ ПРИХОДА ====== -->
                            <!-- ====== ОВЕРЛЕЙ ФИЛЬТРОВ ПРИХОДА ====== -->
                            <Grid x:Name="ArrivalFiltersOverlay"
      Visibility="Collapsed"
      Background="#80000000"
      Panel.ZIndex="50" Grid.ColumnSpan="2">

                                <Border Background="White"
            Padding="20"
            CornerRadius="10"
            Width="450"
            MinHeight="450"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                                    <StackPanel>

                                        <!-- Кнопка закрыть -->
                                        <Button Content="✖"
                    HorizontalAlignment="Right"
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    Click="CloseArrivalFilters_Click"/>

                                        <TextBlock Text="Фильтры прихода"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Margin="0,0,0,16"/>

                                        <!-- ====== ТИПЫ (ГРУППЫ) ====== -->
                                        <TextBlock Text="Тип материалов"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

                                        <WrapPanel x:Name="ArrivalTypesPanel"
                       Margin="0,6,0,10"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Width="400"/>

                                        <!-- ====== КАТЕГОРИЯ ====== -->
                                        <TextBlock Text="Категория"
                       FontWeight="SemiBold"
                       Margin="0,10,0,6"/>

                                        <StackPanel>
                                            <CheckBox x:Name="ArrivalMainCheck"
                          Content="Основные"
                          IsChecked="True"
                          Checked="ArrivalFilters_Changed"
                          Unchecked="ArrivalFilters_Changed"/>

                                            <CheckBox x:Name="ArrivalExtraCheck"
                          Content="Дополнительные"
                          IsChecked="True"
                          Checked="ArrivalFilters_Changed"
                          Unchecked="ArrivalFilters_Changed"/>

                                            <StackPanel x:Name="ArrivalExtraSubtypeFiltersPanel" Margin="20,6,0,0">
                                                <CheckBox x:Name="ArrivalLowCostCheck"
                              Content="Малоценка"
                              IsChecked="True"
                              Checked="ArrivalFilters_Changed"
                              Unchecked="ArrivalFilters_Changed"/>

                                                <CheckBox x:Name="ArrivalInternalCheck"
                              Content="Внутренние"
                              IsChecked="True"
                              Checked="ArrivalFilters_Changed"
                              Unchecked="ArrivalFilters_Changed"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- ====== НАИМЕНОВАНИЕ ====== -->
                                        <TextBlock Text="Наименование"
                       FontWeight="SemiBold"
                       Margin="0,12,0,6"/>

                                        <ScrollViewer Height="180"
                          VerticalScrollBarVisibility="Auto">
                                            <WrapPanel x:Name="ArrivalNamesPanel"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Width="400"/>
                                        </ScrollViewer>

                                        <!-- ====== ПЕРИОД ====== -->
                                        <TextBlock Text="Период"
                       FontWeight="SemiBold"
                       Margin="0,12,0,4"/>

                                        <StackPanel Orientation="Horizontal">
                                            <DatePicker x:Name="ArrivalDateFrom"
                Margin="0,0,8,0"
                SelectedDateChanged="ArrivalFilters_Changed"
                Width="150"/>

                                            <TextBlock Text=" — "
               VerticalAlignment="Center"
               Margin="0,0,8,0"/>

                                            <DatePicker x:Name="ArrivalDateTo"
                SelectedDateChanged="ArrivalFilters_Changed"
                Width="150"/>
                                        </StackPanel>


                                        <!-- ====== КНОПКИ ====== -->
                                        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,20,0,0">

                                            <Button Content="🔄 Сбросить фильтры"
            Width="160"
            Height="34"
            Padding="10,0"
            Background="#EFEFF4"
            BorderBrush="#D0D0D5"
            Foreground="#444"
            FontSize="13"
            FontWeight="SemiBold"
            Click="ArrivalClearFilters_Click"/>
                                        </StackPanel>



                                    </StackPanel>

                                </Border>
                            </Grid>



                            <!-- ====== ПАНЕЛЬ ДОБАВЛЕНИЯ (ОКНО СВЕРХУ) ====== -->
                            <Border x:Name="ArrivalPopup"
                Background="#AA000000"
                Visibility="Collapsed"
                Panel.ZIndex="10" Grid.ColumnSpan="2">
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Background="White"
                        CornerRadius="6"
                        Padding="10"
                        Width="800"
                        MinHeight="300">

                                        <StackPanel>
                                            <local:ArrivalControl x:Name="ArrivalPanel"/>

                                            <Button Content="✖ Закрыть"
                                                               HorizontalAlignment="Right"
                                                               Width="120"
                                                               Height="32"
                                                               Margin="0,10,0,0"
                                                               Click="HideArrivalButton_Click"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                        </Grid>
                    </TabItem>
                        <TabItem x:Name="OtTab" Header="ОТ">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox x:Name="OtSearchTextBox"
                                             Grid.Row="0"
                                             Width="360"
                                             Tag="Поиск по ФИО, например: Иванов"
                                             TextChanged="OtSearchTextBox_TextChanged"/>

                                    <WrapPanel Grid.Row="1" Margin="0,12,0,0">
                                        <Button Style="{StaticResource PrimaryButton}" Click="AddOtRow_Click">➕ Добавить запись</Button>
                                        <Button Style="{StaticResource SecondaryButton}" Click="MarkSelectedRepeatDone_Click" Margin="8,0,0,0">✅ Отметить повторный</Button>
                                        <Button Style="{StaticResource SecondaryButton}" Click="MarkSelectedPersonDismissed_Click" Margin="8,0,0,0">🚫 Снять с объекта</Button>
                                        <Button Style="{StaticResource SecondaryButton}" Click="DeleteSelectedOtRow_Click" Margin="8,0,0,0">🗑 Удалить запись</Button>
                                    </WrapPanel>
                                </Grid>
                            </Border>

                            <DataGrid x:Name="OtJournalGrid"
                                      Grid.Row="2"
                                      AutoGenerateColumns="False"
                                      ColumnWidth="Auto"
                                       CanUserResizeColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="True"
                                      RowStyle="{StaticResource OtDueRowStyle}"
                                      RowEditEnding="OtJournalGrid_RowEditEnding"
                                      CellEditEnding="OtJournalGrid_CellEditEnding"
                                      PreviewKeyDown="OtJournalGrid_PreviewKeyDown">
                                <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Дата" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding InstructionDate, StringFormat=dd.MM.yyyy}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <DatePicker SelectedDate="{Binding InstructionDate, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="ФИО" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                    <TextBlock Text="{Binding FullNameDisplay}" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                            <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="Фамилия Имя Отчество"
                                                        
                                                         TextWrapping="NoWrap"
                                                         VerticalContentAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Специальность" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Specialty}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=Specialties}"
                                                          Text="{Binding Specialty, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Разряд" Binding="{Binding Rank, UpdateSourceTrigger=PropertyChanged}" Width="Auto"/>
                                        <DataGridTextColumn Header="Вид инструктажа" Binding="{Binding InstructionType}" Width="Auto"/>
                                        <DataGridTextColumn Header="Номера инструкций по ОТ" Binding="{Binding InstructionNumbers}" Width="SizeToHeader">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                            <DataGridTextColumn.EditingElementStyle>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                    <Setter Property="AcceptsReturn" Value="True"/>
                                                </Style>
                                            </DataGridTextColumn.EditingElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Период повторного (мес.)"
                                                        Binding="{Binding RepeatPeriodMonths, UpdateSourceTrigger=PropertyChanged}"
                                                       Width="Auto"/>

                                        <DataGridCheckBoxColumn Header="Бригадир" Binding="{Binding IsBrigadier, UpdateSourceTrigger=PropertyChanged}" Width="Auto"/>

                                        <DataGridTemplateColumn Header="Бригадир звена" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BrigadierName}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding ElementName=RootWindow, Path=BrigadierNames}"
                                                          SelectedItem="{Binding BrigadierName, UpdateSourceTrigger=PropertyChanged}"
                                                                                                                    IsEnabled="{Binding IsWorker}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding StringFormat={}{0} - бригадир}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="След. повторный" Binding="{Binding NextRepeatDate, StringFormat=dd.MM.yyyy}" Width="Auto" IsReadOnly="True"/>

                                        <DataGridTemplateColumn Header="Статус" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusLabel}" FontWeight="SemiBold"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Действие" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Отметить пройдено"
                                                        Padding="8,3"
                                                        Click="MarkRepeatDoneRow_Click"
                                                                                                                IsEnabled="{Binding IsActionEnabled}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Сотрудник" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Нет на объекте"
                                                        Padding="8,3"
                                                        Click="MarkPersonDismissedRow_Click"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                           
                        </Grid>
                    </TabItem>
                        <TabItem x:Name="TimesheetTab" Header="Табель">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0" Style="{StaticResource SecondaryButton}" Click="TimesheetPrevMonth_Click">◀ Предыдущий</Button>
                                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Click="TimesheetCurrentMonth_Click" Margin="8,0,0,0">Сегодня</Button>
                                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="TimesheetNextMonth_Click" Margin="8,0,0,0">Следующий ▶</Button>
                                            <TextBlock x:Name="TimesheetMonthText" Grid.Column="3" Margin="16,0,18,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                                <ComboBox x:Name="TimesheetBrigadeFilter"
                                                      Grid.Column="4"
                                                      Width="210"
                                                      Tag="Фильтр по бригаде"
                                                      SelectionChanged="TimesheetBrigadeFilter_SelectionChanged"/>
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource SecondaryButton}" Click="TimesheetPrintFilled_Click">🖨 Печать табеля</Button>
                                                <Button Style="{StaticResource SecondaryButton}" Click="TimesheetPrintBlank_Click" Margin="8,0,0,0">🖨 Печать пустого</Button>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="TimesheetFullNameTextBox" Grid.Column="0" Margin="0,0,10,0" Tag="ФИО сотрудника"/>
                                            <TextBox x:Name="TimesheetSpecialtyTextBox" Grid.Column="1" Margin="0,0,10,0" Tag="Специальность"/>
                                            <TextBox x:Name="TimesheetRankTextBox" Grid.Column="2" Margin="0,0,10,0" Tag="Разряд"/>
                                            <ComboBox x:Name="TimesheetBrigadeComboBox"
                                                      Grid.Column="3"
                                                      Margin="0,0,10,0"
                                                      Tag="Название бригады"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"
                                                      StaysOpenOnEdit="True"
                                                      ItemsSource="{Binding ElementName=RootWindow, Path=TimesheetAssignableBrigades}"/>
                                            <CheckBox x:Name="TimesheetIsBrigadierCheckBox" Grid.Column="4" Content="Бригадир" Margin="0,0,12,0"/>
                                            <WrapPanel Grid.Column="5" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource PrimaryButton}" Click="AddTimesheetPerson_Click">➕ Добавить</Button>
                                                <Button Style="{StaticResource SecondaryButton}" Click="DeleteTimesheetPerson_Click" Margin="8,0,0,0">🗑 Удалить</Button>
                                                <Button Style="{StaticResource SecondaryButton}" Click="EditSelectedDayComment_Click" Margin="8,0,0,0">💬 Комментарий</Button>
                                                <Button Style="{StaticResource SecondaryButton}" Click="ToggleSelectedDayDocument_Click" Margin="8,0,0,0">📄 Документ</Button>
                                            </WrapPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                <DataGrid x:Name="TimesheetGrid"
                                      Grid.Row="0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      ColumnWidth="Auto"
                                      HeadersVisibility="Column"
                                      local:DataGridSizingHelper.EnableSmartSizing="False"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True"
                                      BeginningEdit="TimesheetGrid_BeginningEdit"
                                      CellEditEnding="TimesheetGrid_CellEditEnding"
                                      RowEditEnding="TimesheetGrid_RowEditEnding"
                                      LoadingRow="TimesheetGrid_LoadingRow"
                                      AutoGeneratingColumn="TimesheetGrid_AutoGeneratingColumn"
                                      SelectionUnit="Cell"
                                      SelectionMode="Extended"
                                      SelectedCellsChanged="TimesheetGrid_SelectedCellsChanged"
                                      PreviewKeyDown="TimesheetGrid_PreviewKeyDown"/>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="ProductionTab" Header="ПР">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.9*"/>
                                                <ColumnDefinition Width="1.1*"/>
                                                <ColumnDefinition Width="1.1*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Дата" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <DatePicker x:Name="ProductionDatePicker"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="Вид работы" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ProductionActionBox"
                                                          Tag="Например: монтаж"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=ProductionActions}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                                <TextBlock Text="Чего" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ProductionWorkBox"
                                                          Tag="Тип элементов, например: ригелей"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          SelectionChanged="ProductionWorkBox_SelectionChanged"
                                                          LostFocus="ProductionWorkBox_LostFocus"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=ProductionTargets}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.9*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Элементы и количество" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox x:Name="ProductionElementsBox"
                                                             Grid.Column="0"
                                                             IsReadOnly="True"
                                                             Tag="Выберите элементы и количество через отдельное окно"
                                                             VerticalContentAlignment="Center"/>

                                                    <Button Grid.Column="1"
                                                            Content="Элементы..."
                                                            Margin="10,0,0,0"
                                                            MinWidth="118"
                                                            Click="EditProductionItems_Click"/>

                                                    <Button Grid.Column="2"
                                                            Content="Автозаполнить"
                                                            Margin="10,0,0,0"
                                                            MinWidth="132"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Click="AutoFillProduction_Click"/>

                                                    <Button Grid.Column="3"
                                                            Content="Настройки"
                                                            Margin="10,0,0,0"
                                                            MinWidth="118"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Click="ConfigureProductionAutoFill_Click"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="Блоки" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ProductionBlocksBox"
                                                          Tag="Например: 1, 2"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="False"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=ProductionBlockOptions}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                                <TextBlock Text="Отметки" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ProductionMarksBox"
                                                          Tag="Например: +0.080, +3.220"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="False"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=ProductionMarkOptions}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="Бригада" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ProductionBrigadeBox"
                                                          Tag="Какая бригада выполняла"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=TimesheetAssignableBrigades}"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1.8*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Погода" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ProductionWeatherBox"
                                                          Tag="Например: +15, ясно"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=ProductionWeatherOptions}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="Отклонения" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ProductionDeviationBox"
                                                          Tag="Например: отклонение от осей +3 мм"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=ProductionDeviationOptions}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <CheckBox x:Name="ProductionHiddenWorksCheckBox" Content="Нужен акт скрытых работ" Margin="0,0,14,8"/>
                                                <Button Content="Акт" IsEnabled="False" Style="{StaticResource SecondaryButton}" MinWidth="88" Margin="0,0,10,0"/>
                                                <Button x:Name="ProductionSaveButton" Content="➕ Добавить" Click="SaveProductionForm_Click" MinWidth="132"/>
                                                <Button Content="Очистить" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" MinWidth="110" Click="ClearProductionForm_Click"/>
                                                <Button Content="🗑 Удалить" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" MinWidth="110" Click="DeleteProductionRow_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                                    <DataGrid x:Name="ProductionJournalGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ColumnWidth="Auto"
                                          SelectionChanged="ProductionJournalGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Дата" Width="115">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Date, StringFormat=dd.MM.yyyy}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <DatePicker SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Вид работы" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ActionName}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionActions}"
                                                              Text="{Binding ActionName, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Чего" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WorkName}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionTargets}"
                                                              Text="{Binding WorkName, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Элементы" Width="240">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ElementsText}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionElements}"
                                                              Text="{Binding ElementsText, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Блоки" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BlocksText}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="False"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionBlockOptions}"
                                                              Text="{Binding BlocksText, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Отметки" Width="140">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding MarksText}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="False"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionMarkOptions}"
                                                              Text="{Binding MarksText, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Бригада" Width="170">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BrigadeName}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=TimesheetAssignableBrigades}"
                                                              Text="{Binding BrigadeName, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Погода" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Weather}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionWeatherOptions}"
                                                              Text="{Binding Weather, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Отклонения" Width="240">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Deviations}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionDeviationOptions}"
                                                              Text="{Binding Deviations, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridCheckBoxColumn Header="Скрытые работы" Binding="{Binding RequiresHiddenWorkAct, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                        <DataGridTextColumn Header="Остаток по блоку/отметке" Binding="{Binding RemainingInfo}" Width="280" IsReadOnly="True"/>

                                        <DataGridTemplateColumn Header="Акт" Width="350">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Акт" IsEnabled="False" ToolTip="Подготовим на следующем шаге"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="InspectionTab" Header="Осмотры">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Журнал" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="InspectionJournalNameBox"
                                                          Tag="Например: журнал осмотра стропов"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=InspectionJournalNames}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="Осмотр" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="InspectionNameBox"
                                                          Tag="Например: осмотр лесов"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          StaysOpenOnEdit="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=InspectionNames}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                                <TextBlock Text="Напоминать с" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <DatePicker x:Name="InspectionReminderStartDatePicker"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="Периодичность, дней" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBox x:Name="InspectionPeriodDaysTextBox" Tag="Например: 7"/>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Последний осмотр" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <DatePicker x:Name="InspectionLastCompletedDatePicker"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                <TextBlock Text="Комментарий" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBox x:Name="InspectionNotesTextBox"
                                                         Tag="Например: осмотр выполнен, замечаний нет"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <Button Style="{StaticResource SecondaryButton}" MinWidth="150" Click="MarkInspectionCompleted_Click">✅ Проведен</Button>
                                                <Button x:Name="InspectionSaveButton" Content="➕ Добавить" MinWidth="132" Margin="10,0,0,0" Click="SaveInspectionForm_Click"/>
                                                <Button Content="Очистить" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" MinWidth="110" Click="ClearInspectionForm_Click"/>
                                                <Button Content="🗑 Удалить" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" MinWidth="110" Click="DeleteInspectionRow_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                                    <DataGrid x:Name="InspectionJournalGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              ColumnWidth="Auto"
                                              SelectionChanged="InspectionJournalGrid_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Журнал" Binding="{Binding JournalName}" Width="220"/>
                                            <DataGridTextColumn Header="Осмотр" Binding="{Binding InspectionName}" Width="220"/>
                                            <DataGridTextColumn Header="Напоминать с" Binding="{Binding ReminderStartDate, StringFormat=dd.MM.yyyy}" Width="120"/>
                                            <DataGridTextColumn Header="Период, дней" Binding="{Binding ReminderPeriodDays}" Width="110"/>
                                            <DataGridTextColumn Header="Последний осмотр" Binding="{Binding LastCompletedDate, StringFormat=dd.MM.yyyy}" Width="130"/>
                                            <DataGridTextColumn Header="Следующее напоминание" Binding="{Binding NextReminderDate, StringFormat=dd.MM.yyyy}" Width="150"/>
                                            <DataGridTextColumn Header="Статус" Binding="{Binding ReminderStatus}" Width="220"/>
                                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Notes}" Width="260"/>
                                            <DataGridTemplateColumn Header="Действие" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource SecondaryButton}"
                                                                Content="Проведен"
                                                                MinWidth="100"
                                                                Click="MarkInspectionCompleted_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="PdfTab" Header="ПДФ" Style="{StaticResource HiddenPinnedTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                                    <WrapPanel>
                                        <Button Content="Выбрать PDF"
                                                Click="AddPdfFiles_Click"/>
                                        <Button Content="Новая папка"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="AddPdfFolder_Click"/>
                                        <Button Content="Переименовать"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="RenamePdfNode_Click"/>
                                        <Button Content="Удалить"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="DeletePdfNode_Click"/>
                                        <Button Content="Вверх"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="MovePdfNodeUp_Click"/>
                                        <Button Content="Вниз"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="MovePdfNodeDown_Click"/>
                                        <Button Content="Открыть"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OpenPdfNode_Click"/>
                                    </WrapPanel>
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="PdfTreeHoverColumn" Width="28"/>
                                        <ColumnDefinition x:Name="PdfTreeColumn" Width="320"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="PdfTreeHoverStrip"
                                            Grid.Column="0"
                                            Background="#EEF4FB"
                                            BorderBrush="#D6E2F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,4,0"
                                            MouseEnter="PdfTreeHoverZone_MouseEnter">
                                        <Grid>
                                            <TextBlock Text="Дерево PDF"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#526173"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.LayoutTransform>
                                                    <RotateTransform Angle="-90"/>
                                                </TextBlock.LayoutTransform>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="PdfTreePanelBorder"
                                            Grid.Column="1"
                                            Style="{StaticResource CardBorderStyle}"
                                            Margin="0,0,12,0"
                                            MouseEnter="PdfTreePanel_MouseEnter"
                                            MouseLeave="PdfTreePanel_MouseLeave">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <ToggleButton x:Name="PdfTreePinToggle"
                                                          Width="24"
                                                          Height="24"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Top"
                                                          Margin="0,0,0,6"
                                                          ToolTip="Закрепить дерево PDF"
                                                          Checked="PdfTreePinToggle_Checked"
                                                          Unchecked="PdfTreePinToggle_Unchecked">📎</ToggleButton>

                                            <TreeView x:Name="PdfTreeView"
                                                      Grid.Row="1"
                                                      AllowDrop="True"
                                                      SelectedItemChanged="PdfTreeView_SelectedItemChanged"
                                                      PreviewMouseLeftButtonDown="PdfTreeView_PreviewMouseLeftButtonDown"
                                                      MouseMove="PdfTreeView_MouseMove"
                                                      Drop="PdfTreeView_Drop">
                                                <TreeView.Resources>
                                                    <HierarchicalDataTemplate DataType="{x:Type local:DocumentTreeNode}" ItemsSource="{Binding Children}">
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </HierarchicalDataTemplate>
                                                </TreeView.Resources>
                                            </TreeView>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="0"
                                            Style="{StaticResource CardBorderStyle}"
                                            MouseEnter="PdfPreviewArea_MouseEnter">
                                        <Grid>
                                            <StackPanel x:Name="PdfInfoPanel"
                                                        Margin="14">
                                                <TextBlock Text="ПДФ-документы" FontSize="20" FontWeight="SemiBold"/>
                                                <TextBlock Text="Выберите один или несколько PDF-файлов, затем разложите их по своему дереву. Папки, названия и расположение узлов можно менять в любой момент."
                                                           Margin="0,8,0,16"
                                                           Foreground="#64748B"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="Выбранный узел" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="PdfSelectedNameText"
                                                           Margin="0,6,0,10"
                                                           FontSize="16"
                                                           Text="Ничего не выбрано"/>
                                                <TextBlock Text="Путь к файлу" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="PdfSelectedPathText"
                                                           Margin="0,6,0,10"
                                                           Foreground="#475569"
                                                           TextWrapping="Wrap"
                                                           Text="—"/>
                                                <TextBlock Text="Тип узла" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="PdfSelectedTypeText"
                                                           Margin="0,6,0,0"
                                                           Foreground="#475569"
                                                           Text="—"/>
                                            </StackPanel>

                                            <Border x:Name="PdfPreviewContainer"
                                                    Background="#F8FAFC"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="0"
                                                    Margin="0"
                                                    Visibility="Collapsed">
                                                <Grid>
                                                    <WebBrowser x:Name="PdfPreviewBrowser"
                                                                Visibility="Collapsed"/>
                                                    <Border x:Name="PdfPreviewPlaceholder"
                                                            Background="Transparent">
                                                        <StackPanel HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    MaxWidth="420">
                                                            <TextBlock Text="Предпросмотр"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="18"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock x:Name="PdfPreviewStatusText"
                                                                       Margin="0,10,0,0"
                                                                       Foreground="#64748B"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap"
                                                                       Text="Выберите PDF-файл в дереве слева, и он откроется здесь."/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="EstimateTab" Header="Сметы" Style="{StaticResource HiddenPinnedTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,12">
                                    <WrapPanel>
                                        <Button Content="Выбрать сметы"
                                                Click="AddEstimateFiles_Click"/>
                                        <Button Content="Новая папка"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="AddEstimateFolder_Click"/>
                                        <Button Content="Переименовать"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="RenameEstimateNode_Click"/>
                                        <Button Content="Удалить"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="DeleteEstimateNode_Click"/>
                                        <Button Content="Вверх"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="MoveEstimateNodeUp_Click"/>
                                        <Button Content="Вниз"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="MoveEstimateNodeDown_Click"/>
                                        <Button Content="Открыть"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="OpenEstimateNode_Click"/>
                                    </WrapPanel>
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="EstimateTreeHoverColumn" Width="28"/>
                                        <ColumnDefinition x:Name="EstimateTreeColumn" Width="320"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="EstimateTreeHoverStrip"
                                            Grid.Column="0"
                                            Background="#EEF4FB"
                                            BorderBrush="#D6E2F0"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,4,0"
                                            MouseEnter="EstimateTreeHoverZone_MouseEnter">
                                        <Grid>
                                            <TextBlock Text="Дерево смет"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#526173"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.LayoutTransform>
                                                    <RotateTransform Angle="-90"/>
                                                </TextBlock.LayoutTransform>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="EstimateTreePanelBorder"
                                            Grid.Column="1"
                                            Style="{StaticResource CardBorderStyle}"
                                            Margin="0,0,12,0"
                                            MouseEnter="EstimateTreePanel_MouseEnter"
                                            MouseLeave="EstimateTreePanel_MouseLeave">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <ToggleButton x:Name="EstimateTreePinToggle"
                                                          Width="24"
                                                          Height="24"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Top"
                                                          Margin="0,0,0,6"
                                                          ToolTip="Закрепить дерево смет"
                                                          Checked="EstimateTreePinToggle_Checked"
                                                          Unchecked="EstimateTreePinToggle_Unchecked">📎</ToggleButton>

                                            <TreeView x:Name="EstimateTreeView"
                                                      Grid.Row="1"
                                                      AllowDrop="True"
                                                      SelectedItemChanged="EstimateTreeView_SelectedItemChanged"
                                                      PreviewMouseLeftButtonDown="EstimateTreeView_PreviewMouseLeftButtonDown"
                                                      MouseMove="EstimateTreeView_MouseMove"
                                                      Drop="EstimateTreeView_Drop">
                                                <TreeView.Resources>
                                                    <HierarchicalDataTemplate DataType="{x:Type local:DocumentTreeNode}" ItemsSource="{Binding Children}">
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </HierarchicalDataTemplate>
                                                </TreeView.Resources>
                                            </TreeView>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="0"
                                            Style="{StaticResource CardBorderStyle}"
                                            MouseEnter="EstimatePreviewArea_MouseEnter">
                                        <Grid>
                                            <StackPanel x:Name="EstimateInfoPanel"
                                                        Margin="14">
                                                <TextBlock Text="Сметы" FontSize="20" FontWeight="SemiBold"/>
                                                <TextBlock Text="Выберите файлы смет и соберите для них свою структуру дерева. Можно создавать папки, переименовывать узлы и перемещать их мышкой."
                                                           Margin="0,8,0,16"
                                                           Foreground="#64748B"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="Выбранный узел" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="EstimateSelectedNameText"
                                                           Margin="0,6,0,10"
                                                           FontSize="16"
                                                           Text="Ничего не выбрано"/>
                                                <TextBlock Text="Путь к файлу" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="EstimateSelectedPathText"
                                                           Margin="0,6,0,10"
                                                           Foreground="#475569"
                                                           TextWrapping="Wrap"
                                                           Text="—"/>
                                                <TextBlock Text="Тип узла" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="EstimateSelectedTypeText"
                                                           Margin="0,6,0,0"
                                                           Foreground="#475569"
                                                           Text="—"/>
                                            </StackPanel>

                                            <Border x:Name="EstimatePreviewContainer"
                                                    Background="#F8FAFC"
                                                    BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="0"
                                                    Margin="0"
                                                    SizeChanged="EstimatePreviewContainer_SizeChanged"
                                                    Visibility="Collapsed">
                                                <Grid>
                                                    <wfi:WindowsFormsHost x:Name="EstimateExcelHost"
                                                                          Visibility="Collapsed"/>
                                                    <WebBrowser x:Name="EstimatePreviewBrowser"
                                                                Visibility="Collapsed"/>
                                                    <Border x:Name="EstimatePreviewPlaceholder"
                                                            Background="Transparent">
                                                        <StackPanel HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    MaxWidth="420">
                                                            <TextBlock Text="Предпросмотр"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="18"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock x:Name="EstimatePreviewStatusText"
                                                                       Margin="0,10,0,0"
                                                                       Foreground="#64748B"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap"
                                                                       Text="Выберите файл сметы в дереве слева, и он откроется здесь."/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>



                    </TabControl>
                </Grid>
              </Border>
        </Grid>
        </DockPanel>
        
    </Grid>
</Window>
