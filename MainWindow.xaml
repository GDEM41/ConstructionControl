                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionTargets}"
                                                              Text="{Binding WorkName, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Элементы" Width="240">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding ElementsDisplay}"
                                                               TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionElements}"
                                                              Text="{Binding ElementsText, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Блоки" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BlocksDisplayText}" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="False"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionBlockOptions}"
                                                              Text="{Binding BlocksText, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Отметки" Width="140">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding MarksText}"
                                                               TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="False"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionMarkOptions}"
                                                              Text="{Binding MarksText, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Бригада" Width="170">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding BrigadeName}"
                                                               TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=TimesheetAssignableBrigades}"
                                                              Text="{Binding BrigadeName, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Погода" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WeatherDisplay}"
                                                               TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionWeatherOptions}"
                                                              Text="{Binding Weather, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Отклонения" Width="240">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding DeviationsDisplay}"
                                                               TextWrapping="Wrap"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                            <DataGridTemplateColumn.CellEditingTemplate>
                                                <DataTemplate>
                                                    <ComboBox IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=ProductionDeviationOptions}"
                                                              Text="{Binding Deviations, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridCheckBoxColumn Header="Скрытые работы" Binding="{Binding RequiresHiddenWorkAct, UpdateSourceTrigger=PropertyChanged}" Width="56"/>
                                        <DataGridTextColumn Header="Остаток по блоку/отметке" Binding="{Binding RemainingInfo}" Width="280" IsReadOnly="True"/>

                                        <DataGridTemplateColumn Header="Акт" Width="350">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="Акт"
                                                            Tag="{Binding}"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Click="ProductionOpenHiddenWorkAct_Click"
                                                            IsEnabled="{Binding RequiresHiddenWorkAct}"
                                                            ToolTip="Открыть соответствующий акт скрытых работ"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="HiddenWorkActsTab" Header="Акты">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Style="{StaticResource CardBorderStyle}"
                                        Margin="0,0,0,12">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  CanContentScroll="False">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Обновить"
                                                    Height="32"
                                                    MinWidth="98"
                                                    Click="RefreshHiddenWorkActs_Click"/>
                                            <Button x:Name="FixHiddenWorkActButton"
                                                    Content="Зафиксировать"
                                                    Height="32"
                                                    MinWidth="126"
                                                    Margin="8,0,0,0"
                                                    Click="FixSelectedHiddenWorkAct_Click"/>
                                            <Button x:Name="UnfixHiddenWorkActButton"
                                                    Content="Снять фиксацию"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="32"
                                                    MinWidth="146"
                                                    Margin="8,0,0,0"
                                                    Click="UnfixSelectedHiddenWorkAct_Click"/>
                                            <Button x:Name="PrintSelectedHiddenWorkActButton"
                                                    Content="Печать"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="32"
                                                    MinWidth="98"
                                                    Margin="8,0,0,0"
                                                    Click="PrintSelectedHiddenWorkAct_Click"/>
                                            <Button x:Name="PrintPendingHiddenWorkActsButton"
                                                    Content="Печать нераспечатанных"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="32"
                                                    MinWidth="196"
                                                    Margin="8,0,0,0"
                                                    Click="PrintPendingHiddenWorkActs_Click"/>
                                            <Button x:Name="DeleteHiddenWorkActButton"
                                                    Content="Удалить акт"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="32"
                                                    MinWidth="116"
                                                    Margin="8,0,0,0"
                                                    Click="DeleteSelectedHiddenWorkAct_Click"/>
                                            <TextBlock x:Name="HiddenWorkActsSummaryText"
                                                       Margin="16,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <Grid Grid.Row="1" x:Name="HiddenWorkActsContentGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.95*"/>
                                        <ColumnDefinition Width="1.05*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Margin="0,0,12,0" x:Name="HiddenWorkActsLeftGrid">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="0.56*"/>
                                            <RowDefinition Height="0.44*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Style="{StaticResource CardBorderStyle}"
                                                Margin="0,0,0,12">
                                            <DataGrid x:Name="HiddenWorkActsGrid"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      SelectionMode="Single"
                                                      EnableRowVirtualization="True"
                                                      EnableColumnVirtualization="True"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                                      SelectionChanged="HiddenWorkActsGrid_SelectionChanged">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Дата акта"
                                                                        Binding="{Binding EndDateText}"
                                                                        Width="92"
                                                                        IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Работы"
                                                                        Binding="{Binding TitleDisplay}"
                                                                        Width="*"
                                                                        IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Период"
                                                                        Binding="{Binding PeriodDisplay}"
                                                                        Width="154"
                                                                        IsReadOnly="True"/>
                                                    <DataGridTextColumn Header="Материалы"
                                                                        Binding="{Binding MaterialsSummary}"
                                                                        Width="180"
                                                                        IsReadOnly="True"/>
                                                    <DataGridTemplateColumn Header="Фикс." Width="62">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <CheckBox IsChecked="{Binding IsFixed, UpdateSourceTrigger=PropertyChanged}"
                                                                          HorizontalAlignment="Center"
                                                                          Click="HiddenWorkActFixedCheckBox_Click"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridTemplateColumn Header="Печ." Width="62">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <CheckBox IsChecked="{Binding IsPrinted, UpdateSourceTrigger=PropertyChanged}"
                                                                          HorizontalAlignment="Center"
                                                                          Click="HiddenWorkActPrintedCheckBox_Click"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Border>

                                        <Border Grid.Row="1"
                                                Style="{StaticResource CardBorderStyle}"
                                                x:Name="HiddenWorkActEditorBorder">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="HiddenWorkActEditorPanel">
                                                    <TextBlock Text="Редактирование акта"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,10"/>

                                                    <Grid Margin="0,0,0,10" x:Name="HiddenWorkActHeaderEditorGrid">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                            <TextBlock Text="Название работ" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <TextBox x:Name="HiddenWorkActTitleBox"
                                                                     Text="{Binding WorkTitle, UpdateSourceTrigger=LostFocus}"
                                                                     LostFocus="HiddenWorkActEditorField_LostFocus"
                                                                     AcceptsReturn="True"
                                                                     TextWrapping="Wrap"
                                                                     MinHeight="64"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="Название объекта" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <TextBox x:Name="HiddenWorkActObjectNameBox"
                                                                     Text="{Binding FullObjectName, UpdateSourceTrigger=LostFocus}"
                                                                     LostFocus="HiddenWorkActEditorField_LostFocus"
                                                                     AcceptsReturn="True"
                                                                     TextWrapping="Wrap"
                                                                     MinHeight="64"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,10" x:Name="HiddenWorkActDatesEditorGrid">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                            <TextBlock Text="Начало работ" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <DatePicker x:Name="HiddenWorkActStartDatePicker"
                                                                        Style="{StaticResource ArrivalFilterDatePicker}"
                                                                        SelectedDateFormat="Short"
                                                                        SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectedDateChanged="HiddenWorkActDate_SelectedDateChanged"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                            <TextBlock Text="Окончание работ" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <DatePicker x:Name="HiddenWorkActEndDatePicker"
                                                                        Style="{StaticResource ArrivalFilterDatePicker}"
                                                                        SelectedDateFormat="Short"
                                                                        SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectedDateChanged="HiddenWorkActDate_SelectedDateChanged"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Статус" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <TextBlock x:Name="HiddenWorkActStatusText"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Text="Генподрядчик" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="HiddenWorkActGeneralContractorBox"
                                                             Text="{Binding GeneralContractorInfo, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="HiddenWorkActEditorField_LostFocus"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="52"
                                                             Margin="0,0,0,8"/>

                                                    <TextBlock Text="Субподрядчик (представитель)" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="HiddenWorkActSubcontractorBox"
                                                             Text="{Binding SubcontractorInfo, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="HiddenWorkActEditorField_LostFocus"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="52"
                                                             Margin="0,0,0,8"/>

                                                    <TextBlock Text="Технический надзор" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="HiddenWorkActTechnicalSupervisorBox"
                                                             Text="{Binding TechnicalSupervisorInfo, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="HiddenWorkActEditorField_LostFocus"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="52"
                                                             Margin="0,0,0,8"/>

                                                    <TextBlock Text="Проектная организация" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="HiddenWorkActProjectOrganizationBox"
                                                             Text="{Binding ProjectOrganizationInfo, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="HiddenWorkActEditorField_LostFocus"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="52"
                                                             Margin="0,0,0,8"/>

                                                    <TextBlock Text="Выполненные работы" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="HiddenWorkActWorkExecutorBox"
                                                             Text="{Binding WorkExecutorInfo, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="HiddenWorkActEditorField_LostFocus"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="52"
                                                             Margin="0,0,0,8"/>

                                                    <TextBlock Text="Проектная документация" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="HiddenWorkActProjectDocumentationBox"
                                                             Text="{Binding ProjectDocumentation, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="HiddenWorkActEditorField_LostFocus"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="52"
                                                             Margin="0,0,0,8"/>

                                                    <TextBlock Text="Отклонения / согласования" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBox x:Name="HiddenWorkActDeviationsBox"
                                                             Text="{Binding Deviations, UpdateSourceTrigger=LostFocus}"
                                                             LostFocus="HiddenWorkActEditorField_LostFocus"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="52"
                                                             Margin="0,0,0,8"/>

                                                    <Grid Margin="0,0,0,10" x:Name="HiddenWorkActSignersEditorGrid">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                            <TextBlock Text="Подписант подрядчика" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <TextBox x:Name="HiddenWorkActContractorSignerBox"
                                                                     Text="{Binding ContractorSignerName, UpdateSourceTrigger=LostFocus}"
                                                                     LostFocus="HiddenWorkActEditorField_LostFocus"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                            <TextBlock Text="Подписант технадзора" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <TextBox x:Name="HiddenWorkActTechnicalSignerBox"
                                                                     Text="{Binding TechnicalSupervisorSignerName, UpdateSourceTrigger=LostFocus}"
                                                                     LostFocus="HiddenWorkActEditorField_LostFocus"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Подписант авторского надзора" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                            <TextBox x:Name="HiddenWorkActAuthorSignerBox"
                                                                     Text="{Binding ProjectOrganizationSignerName, UpdateSourceTrigger=LostFocus}"
                                                                     LostFocus="HiddenWorkActEditorField_LostFocus"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,8" x:Name="HiddenWorkActMaterialsToolbarGrid">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Материалы"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>
                                                        <WrapPanel Grid.Column="1">
                                                            <Button Content="Подобрать заново"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    Height="28"
                                                                    MinWidth="124"
                                                                    Margin="0,0,8,0"
                                                                    Click="ResetHiddenWorkActMaterials_Click"/>
                                                            <Button Content="+ Материал"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    Height="28"
                                                                    MinWidth="98"
                                                                    Margin="0,0,8,0"
                                                                    Click="AddHiddenWorkActMaterial_Click"/>
                                                            <Button Content="Удалить"
                                                                    Style="{StaticResource SecondaryButton}"
                                                                    Height="28"
                                                                    MinWidth="86"
                                                                    Click="RemoveHiddenWorkActMaterial_Click"/>
                                                        </WrapPanel>
                                                    </Grid>

                                                    <DataGrid x:Name="HiddenWorkActMaterialsGrid"
                                                              AutoGenerateColumns="False"
                                                              CanUserAddRows="False"
                                                              CanUserDeleteRows="False"
                                                              ItemsSource="{Binding Materials}"
                                                              MinHeight="180"
                                                              CellEditEnding="HiddenWorkActMaterialsGrid_CellEditEnding">
                                                        <DataGrid.Columns>
                                                            <DataGridCheckBoxColumn Header="Исп."
                                                                                    Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="56"/>
                                                            <DataGridTextColumn Header="Материал"
                                                                                Binding="{Binding MaterialName, UpdateSourceTrigger=LostFocus}"
                                                                                Width="*"/>
                                                            <DataGridTextColumn Header="Паспорт"
                                                                                Binding="{Binding Passport, UpdateSourceTrigger=LostFocus}"
                                                                                Width="150"/>
                                                            <DataGridTemplateColumn Header="Дата прихода" Width="124">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <Button Content="{Binding ArrivalDateText}"
                                                                                ToolTip="Открыть журнал прихода и выбрать дату"
                                                                                Click="OpenHiddenWorkActMaterialArrivalPicker_Click"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                                    <DataTemplate>
                                                                        <DatePicker SelectedDate="{Binding ArrivalDate, UpdateSourceTrigger=PropertyChanged}"
                                                                                    SelectedDateChanged="HiddenWorkActMaterialDate_SelectedDateChanged"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellEditingTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>
                                                    </DataGrid>

                                                    <TextBlock Text="Материалы можно отключать чекбоксом или редактировать вручную."
                                                               Margin="0,8,0,0"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource CardBorderStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Предпросмотр"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,10"/>
                                            <DocumentViewer x:Name="HiddenWorkActPreviewViewer"
                                                            Grid.Row="1">
                                                <DocumentViewer.CommandBindings>
                                                    <CommandBinding Command="{x:Static input:ApplicationCommands.Print}"
                                                                    CanExecute="HiddenWorkActPreviewPrint_CanExecute"
                                                                    Executed="HiddenWorkActPreviewPrint_Executed"/>
                                                </DocumentViewer.CommandBindings>
                                            </DocumentViewer>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="InspectionTab" Header="Осмотры">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="InspectionToolsHoverStrip"
                                        Grid.Row="0"
                                        Style="{StaticResource AutoHidePanelHoverStripStyle}"
                                        MouseEnter="JournalToolsHoverStrip_MouseEnter"
                                        ToolTip="Наведите курсор, чтобы развернуть панель"
                                        Tag="Inspection">
                                    <TextBlock Text="Панель осмотров (наведите курсор, чтобы развернуть)"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>

                                <Border x:Name="InspectionToolsPanelBorder"
                                        Grid.Row="1"
                                        Style="{StaticResource CardBorderStyle}"
                                        Margin="0,0,0,12"
                                        Visibility="Collapsed"
                                        MouseEnter="JournalToolsPanel_MouseEnter"
                                        MouseLeave="JournalToolsPanel_MouseLeave"
                                        Tag="Inspection">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="116"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Журнал" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <ComboBox x:Name="InspectionJournalNameBox"
                                                              Style="{StaticResource ProductionToolbarFieldComboBox}"
                                                              Tag="Например: журнал осмотра стропов"
                                                              IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=InspectionJournalNames}"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Осмотр" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <ComboBox x:Name="InspectionNameBox"
                                                              Style="{StaticResource ProductionToolbarFieldComboBox}"
                                                              Tag="Например: осмотр лесов"
                                                              IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=InspectionNames}"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Напоминать с" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <DatePicker x:Name="InspectionReminderStartDatePicker"
                                                                Style="{StaticResource ArrivalFilterDatePicker}"
                                                                SelectedDateFormat="Short"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="3"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Периодичность, дней" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="InspectionPeriodDaysTextBox"
                                                             Style="{StaticResource ProductionToolbarFieldTextBox}"
                                                             Tag="Например: 7"
                                                             MaxLength="3"
                                                             PreviewTextInput="DigitsOnlyTextBox_PreviewTextInput"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="4"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Padding="8">
                                                <ToggleButton x:Name="InspectionToolsPinToggle"
                                                              Style="{StaticResource AutoHidePanelPinToggleStyle}"
                                                              Margin="0"
                                                              VerticalAlignment="Top"
                                                              ToolTip="Закрепить панель осмотров"
                                                              Checked="JournalToolsPinToggle_Checked"
                                                              Unchecked="JournalToolsPinToggle_Unchecked"
                                                              Tag="Inspection"/>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Последний осмотр" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <DatePicker x:Name="InspectionLastCompletedDatePicker"
                                                                Style="{StaticResource ArrivalFilterDatePicker}"
                                                                SelectedDateFormat="Short"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Комментарий" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="InspectionNotesTextBox"
                                                             Style="{StaticResource ProductionToolbarFieldTextBox}"
                                                             Tag="Например: осмотр выполнен, замечаний нет"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Disabled"
                                                              CanContentScroll="False"
                                                              VerticalAlignment="Center">
                                                    <WrapPanel VerticalAlignment="Center">
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}" MinWidth="114" Click="ApplyInspectionTemplate_Click">Шаблон ↓</Button>
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}" MinWidth="164" Click="CreateInspectionFromTemplate_Click">Добавить по шаблону</Button>
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}" MinWidth="148" Click="SaveInspectionTemplate_Click">Сохранить шаблон</Button>
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}" MinWidth="118" Click="OpenInspectionReport_Click">Отчет</Button>
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}" MinWidth="150" Click="MarkInspectionCompleted_Click">✅ Проведен</Button>
                                                        <Button x:Name="InspectionSaveButton" Content="➕ Добавить" MinWidth="132" Style="{StaticResource ProductionToolbarPrimaryButton}" Click="SaveInspectionForm_Click"/>
                                                        <Button Content="Очистить" Style="{StaticResource ProductionToolbarSecondaryButton}" MinWidth="110" Click="ClearInspectionForm_Click"/>
                                                        <Button Content="🗑 Удалить" Style="{StaticResource ProductionToolbarSecondaryButton}" Margin="0" MinWidth="110" Click="DeleteInspectionRow_Click"/>
                                                    </WrapPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <WrapPanel Grid.Row="0" Margin="0,0,0,8">
                                            <Border Background="{DynamicResource SelectedBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                                <TextBlock Text="Синий: запланирован следующий осмотр"/>
                                            </Border>
                                            <Border Background="{DynamicResource WarningSoftBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                                <TextBlock Text="Желтый: осмотр просрочен"/>
                                            </Border>
                                            <Border Background="{DynamicResource SuccessSoftBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4">
                                                <TextBlock Text="Зеленый: осмотр проведен, создана следующая запись"/>
                                            </Border>
                                        </WrapPanel>

                                        <DataGrid x:Name="InspectionJournalGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  MinRowHeight="40"
                                                  ColumnWidth="Auto"
                                                  RowHeaderWidth="0"
                                                  RowStyle="{StaticResource InspectionRowStyle}"
                                                  SelectionChanged="InspectionJournalGrid_SelectionChanged"
                                                  PreviewKeyDown="InspectionJournalGrid_PreviewKeyDown">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="Журнал" Width="300">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding JournalDisplay}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Осмотр" Width="320">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding InspectionDisplay}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Напоминать с" Binding="{Binding ReminderStartDate, StringFormat=dd.MM.yyyy}" Width="92"/>
                                                <DataGridTextColumn Header="Период, дней" Binding="{Binding ReminderPeriodDays}" Width="58"/>
                                                <DataGridTextColumn Header="Последний осмотр" Binding="{Binding LastCompletedDate, StringFormat=dd.MM.yyyy}" Width="92"/>
                                                <DataGridTemplateColumn Header="Статус" Width="260">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ReminderStatusDisplay}"
                                                                       TextWrapping="Wrap"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Комментарий" Width="280">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding NotesDisplay}"
                                                                       TextWrapping="Wrap"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Действие" Width="120">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource SecondaryButton}"
                                                                    Content="Проведен"
                                                                    MinWidth="100"
                                                                    Click="MarkInspectionCompleted_Click"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="NotesTab" Header="Заметки">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="NotesToolsHoverStrip"
                                        Grid.Row="0"
                                        Style="{StaticResource AutoHidePanelHoverStripStyle}"
                                        MouseEnter="JournalToolsHoverStrip_MouseEnter"
                                        ToolTip="Наведите курсор, чтобы развернуть панель"
                                        Tag="Notes">
                                    <TextBlock Text="Панель заметок (наведите курсор, чтобы развернуть)"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>

                                <Border x:Name="NotesToolsPanelBorder"
                                        Grid.Row="1"
                                        Style="{StaticResource CardBorderStyle}"
                                        Margin="0,0,0,12"
                                        Visibility="Collapsed"
                                        MouseEnter="JournalToolsPanel_MouseEnter"
                                        MouseLeave="JournalToolsPanel_MouseLeave"
                                        Tag="Notes">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0"
                                              Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Форма заметки"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <ToggleButton x:Name="NotesToolsPinToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource AutoHidePanelPinToggleStyle}"
                                                          Margin="0"
                                                          VerticalAlignment="Top"
                                                          ToolTip="Закрепить панель заметок"
                                                          Checked="JournalToolsPinToggle_Checked"
                                                          Unchecked="JournalToolsPinToggle_Unchecked"
                                                          Tag="Notes"/>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="260"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}">
                                                <StackPanel>
                                                    <TextBlock Text="Заголовок" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="NoteTitleBox"
                                                             Style="{StaticResource ProductionToolbarFieldTextBox}"
                                                             Tag="Например: Согласовать бетон на секцию А"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}">
                                                <StackPanel>
                                                    <TextBlock Text="Режим напоминания" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <ComboBox x:Name="NoteReminderModeBox"
                                                              Style="{StaticResource ProductionToolbarFieldComboBox}"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="4"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}">
                                                <StackPanel>
                                                    <TextBlock Text="Статус задачи" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <CheckBox x:Name="NoteDoneCheckBox"
                                                              Content="Завершено"
                                                              Style="{StaticResource TimesheetFlagCheckBox}"
                                                              Margin="0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Дата старта" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <DatePicker x:Name="NoteReminderStartDatePicker"
                                                                Style="{StaticResource ArrivalFilterDatePicker}"
                                                                SelectedDateFormat="Short"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Время" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="NoteReminderTimeBox"
                                                             Style="{StaticResource ProductionToolbarFieldTextBox}"
                                                             Tag="09:00"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Интервал" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="NoteReminderIntervalValueBox"
                                                             Style="{StaticResource ProductionToolbarFieldTextBox}"
                                                             Text="1"
                                                             MaxLength="4"
                                                             PreviewTextInput="DigitsOnlyTextBox_PreviewTextInput"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="3"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Ед. интервала" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <ComboBox x:Name="NoteReminderIntervalUnitBox"
                                                              Style="{StaticResource ProductionToolbarFieldComboBox}"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="4"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}">
                                                <TextBlock VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Разово: одно напоминание. Периодически: после кнопки &quot;Отметить напоминание&quot; сдвигается на интервал. Постоянно: всегда активно с даты старта."/>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}"
                                                    Margin="0,0,12,0">
                                                <StackPanel>
                                                    <TextBlock Text="Текст заметки" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBox x:Name="NoteBodyBox"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             VerticalScrollBarVisibility="Auto"
                                                             MinHeight="120"
                                                             MaxHeight="180"
                                                             Tag="Подробности, ссылки, TODO, комментарии..."/>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Style="{StaticResource ProductionToolbarSectionBorder}">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Disabled"
                                                              CanContentScroll="False"
                                                              VerticalAlignment="Center">
                                                    <WrapPanel VerticalAlignment="Center">
                                                        <Button x:Name="SaveNoteButton"
                                                                MinWidth="130"
                                                                Style="{StaticResource ProductionToolbarPrimaryButton}"
                                                                Click="SaveNote_Click">💾 Сохранить</Button>
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}"
                                                                MinWidth="110"
                                                                Click="ClearNoteForm_Click">Очистить</Button>
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}"
                                                                MinWidth="188"
                                                                Click="AcknowledgeNoteReminder_Click">🔔 Отметить напоминание</Button>
                                                        <Button Style="{StaticResource ProductionToolbarSecondaryButton}"
                                                                Margin="0"
                                                                MinWidth="110"
                                                                Click="DeleteNote_Click">🗑 Удалить</Button>
                                                    </WrapPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                                    <DataGrid x:Name="NotesGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              IsReadOnly="True"
                                              SelectionMode="Single"
                                              RowHeaderWidth="0"
                                              SelectionChanged="NotesGrid_SelectionChanged">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsReminderDue}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource WarningSoftBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Обновлено"
                                                                Binding="{Binding UpdatedAtLocal, StringFormat=dd.MM.yyyy HH:mm}"
                                                                Width="132"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Заголовок"
                                                                Binding="{Binding TitleDisplay}"
                                                                Width="220"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Заметка"
                                                                Binding="{Binding BodyDisplay}"
                                                                Width="*"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Режим"
                                                                Binding="{Binding ReminderModeDisplay}"
                                                                Width="126"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Интервал"
                                                                Binding="{Binding ReminderIntervalDisplay}"
                                                                Width="110"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Следующее"
                                                                Binding="{Binding NextReminderText}"
                                                                Width="132"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Статус"
                                                                Binding="{Binding ReminderStatusDisplay}"
                                                                Width="128"
                                                                IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="PdfTab" Header="ПДФ" Style="{StaticResource HiddenPinnedTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="PdfTreeHoverColumn" Width="28"/>
                                        <ColumnDefinition x:Name="PdfTreeColumn" Width="320"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="PdfTreeHoverStrip"
                                            Grid.Column="0"
                                            Background="{DynamicResource SelectedBrush}"
                                            BorderBrush="{DynamicResource StrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,4,0"
                                            MouseEnter="PdfTreeHoverZone_MouseEnter">
                                        <Grid>
                                            <TextBlock Text="Дерево PDF"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.LayoutTransform>
                                                    <RotateTransform Angle="-90"/>
                                                </TextBlock.LayoutTransform>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="PdfTreePanelBorder"
                                            Grid.Column="1"
                                            Style="{StaticResource CardBorderStyle}"
                                            Margin="0,0,12,0"
                                            MouseEnter="PdfTreePanel_MouseEnter"
                                            MouseLeave="PdfTreePanel_MouseLeave">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="⋯"
                                                        Width="32"
                                                        Height="24"
                                                        Padding="0"
                                                        FontSize="16"
                                                        Style="{StaticResource SecondaryButton}"
                                                        ToolTip="Действия с PDF"
                                                        Click="PdfActionsMenuButton_Click">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Выбрать PDF" Click="AddPdfFiles_Click"/>
                                                            <MenuItem Header="Новая папка" Click="AddPdfFolder_Click"/>
                                                            <MenuItem Header="Переименовать" Click="RenamePdfNode_Click"/>
                                                            <MenuItem Header="Удалить" Click="DeletePdfNode_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Вверх" Click="MovePdfNodeUp_Click"/>
                                                            <MenuItem Header="Вниз" Click="MovePdfNodeDown_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Поиск по дереву..." Click="SearchPdfNodes_Click"/>
                                                            <MenuItem Header="Пакетное переименование..." Click="BatchRenamePdfNodes_Click"/>
                                                            <MenuItem Header="Реорганизовать по типам" Click="ReorganizePdfNodes_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Открыть" Click="OpenPdfNode_Click"/>
                                                            <MenuItem Header="Отчет по документам" Click="OpenPdfLibraryReport_Click"/>
                                                            <MenuItem Header="Сводный отчет по всем документам" Click="OpenAllDocumentsReport_Click"/>
                                                            <MenuItem Header="Проверка целостности документов" Click="CheckPdfDocumentsIntegrity_Click"/>
                                                            <MenuItem Header="Обслуживание хранилища документов" Click="RunDocumentStorageMaintenance_Click"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>

                                                <ToggleButton x:Name="PdfTreePinToggle"
                                                              Grid.Column="2"
                                                              Width="24"
                                                              Height="24"
                                                              HorizontalAlignment="Right"
                                                              VerticalAlignment="Top"
                                                              Margin="0"
                                                              ToolTip="Закрепить дерево PDF"
                                                              Checked="PdfTreePinToggle_Checked"
                                                              Unchecked="PdfTreePinToggle_Unchecked">📎</ToggleButton>
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox x:Name="PdfTreeSearchBox"
                                                         Grid.Column="0"
                                                         Height="28"
                                                         Margin="0,0,6,0"
                                                         Padding="8,0"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Поиск по PDF"
                                                         KeyDown="PdfTreeSearchBox_KeyDown"/>
                                                <Button Grid.Column="1"
                                                        Content="Найти"
                                                        Height="28"
                                                        MinWidth="72"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="PdfTreeSearchButton_Click"/>
                                                <Button Grid.Column="2"
                                                        Content="Очистить"
                                                        Height="28"
                                                        MinWidth="86"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="PdfTreeSearchClear_Click"/>
                                            </Grid>

                                            <TreeView x:Name="PdfTreeView"
                                                      Grid.Row="2"
                                                      AllowDrop="True"
                                                      SelectedItemChanged="PdfTreeView_SelectedItemChanged"
                                                      PreviewMouseLeftButtonDown="PdfTreeView_PreviewMouseLeftButtonDown"
                                                      MouseMove="PdfTreeView_MouseMove"
                                                      Drop="PdfTreeView_Drop">
                                                <TreeView.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </HierarchicalDataTemplate>
                                                </TreeView.ItemTemplate>
                                            </TreeView>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="0"
                                            Style="{StaticResource CardBorderStyle}"
                                            CornerRadius="0"
                                            MouseEnter="PdfPreviewArea_MouseEnter">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0"
                                                  Margin="10,8,10,6"
                                                  Visibility="Collapsed"
                                                  Height="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ListBox x:Name="PdfTabStrip"
                                                         Grid.Column="0"
                                                         Height="32"
                                                         Margin="0,0,8,0"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                         SelectionChanged="PdfTabStrip_SelectionChanged"
                                                         PreviewMouseLeftButtonDown="PdfTabStrip_PreviewMouseLeftButtonDown"
                                                         MouseMove="PdfTabStrip_MouseMove"
                                                         AllowDrop="True"
                                                         Drop="PdfTabStrip_Drop">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,6,0"
                                                                    Padding="8,4"
                                                                    CornerRadius="10"
                                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                                    BorderBrush="{DynamicResource StrokeBrush}"
