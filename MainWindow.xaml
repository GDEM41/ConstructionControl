                                                <TextBlock Grid.Column="1"
                                                           Margin="0"
                                                           Visibility="Collapsed"/>
                                                <TextBlock Grid.Column="2"
                                                           Margin="0"
                                                           Visibility="Collapsed"/>
                                            </Grid>

                                            <Grid Grid.Row="1" x:Name="PdfSplitGrid"
                                                  AllowDrop="True"
                                                  DragEnter="PdfSplitGrid_DragEnter"
                                                  DragLeave="PdfSplitGrid_DragLeave"
                                                  DragOver="PdfSplitGrid_DragOver"
                                                  Drop="PdfSplitGrid_Drop">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition x:Name="PdfSplitPrimaryColumn" Width="*"/>
                                                    <ColumnDefinition x:Name="PdfSplitDividerColumn" Width="6"/>
                                                    <ColumnDefinition x:Name="PdfSplitSecondaryColumn" Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="PdfPrimaryPane" Grid.Column="0">
                                                    <Grid>
                                                        <StackPanel x:Name="PdfInfoPanel"
                                                                    Margin="14">
                                                            <TextBlock Text="ПДФ-документы" FontSize="20" FontWeight="SemiBold"/>
                                                            <TextBlock Text="Выберите один или несколько PDF-файлов, затем разложите их по своему дереву. Папки, названия и расположение узлов можно менять в любой момент."
                                                                       Margin="0,8,0,16"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="Выбранный узел" FontWeight="SemiBold"/>
                                                            <TextBlock x:Name="PdfSelectedNameText"
                                                                       Margin="0,6,0,10"
                                                                       FontSize="16"
                                                                       Text="Ничего не выбрано"/>
                                                            <TextBlock Text="Путь к файлу" FontWeight="SemiBold"/>
                                                            <TextBlock x:Name="PdfSelectedPathText"
                                                                       Margin="0,6,0,10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Text="—"/>
                                                            <TextBlock Text="Тип узла" FontWeight="SemiBold"/>
                                                            <TextBlock x:Name="PdfSelectedTypeText"
                                                                       Margin="0,6,0,0"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Text="—"/>
                                                        </StackPanel>

                                                <Border x:Name="PdfPreviewContainer"
                                                        Background="{DynamicResource SurfaceAltBrush}"
                                                        BorderBrush="{DynamicResource StrokeBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="0"
                                                        Padding="0"
                                                        Margin="0"
                                                        Visibility="Collapsed"
                                                        SizeChanged="PdfPreviewContainer_SizeChanged">
                                                    <Grid>
                                                        <local:NativeChildHost x:Name="PdfExternalHost"
                                                                               Visibility="Collapsed"/>
                                                        <WebBrowser x:Name="PdfPreviewBrowser"
                                                                    Visibility="Collapsed"/>
                                                        <Border x:Name="PdfPreviewPlaceholder"
                                                                Background="Transparent">
                                                                    <StackPanel HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                MaxWidth="420">
                                                                        <TextBlock Text="Предпросмотр"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="18"
                                                                                   HorizontalAlignment="Center"/>
                                                                        <TextBlock x:Name="PdfPreviewStatusText"
                                                                                   Margin="0,10,0,0"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   TextAlignment="Center"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="Выберите PDF-файл в дереве слева, и он откроется здесь."/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <GridSplitter x:Name="PdfSplitBar"
                                                              Grid.Column="1"
                                                              Width="6"
                                                              Background="{DynamicResource StrokeBrush}"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"
                                                              Visibility="Collapsed"/>

                                                <Border x:Name="PdfPreviewContainerSecondary"
                                                        Grid.Column="2"
                                                        BorderBrush="{DynamicResource StrokeBrush}"
                                                        BorderThickness="1"
                                                        Background="{DynamicResource SurfaceAltBrush}"
                                                        Visibility="Collapsed"
                                                        AllowDrop="True"
                                                        Drop="PdfSecondaryPane_Drop">
                                                    <Grid>
                                                        <WebBrowser x:Name="PdfPreviewBrowserSecondary"
                                                                    Visibility="Collapsed"/>
                                                        <Border x:Name="PdfPreviewPlaceholderSecondary"
                                                                Background="Transparent">
                                                            <StackPanel HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        MaxWidth="420">
                                                                <TextBlock Text="Второй файл"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="16"
                                                                           HorizontalAlignment="Center"/>
                                                                <TextBlock x:Name="PdfPreviewStatusTextSecondary"
                                                                           Margin="0,10,0,0"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"
                                                                           Text="Перетащите вкладку сюда для открытия рядом."/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <Grid x:Name="PdfSplitDropOverlay"
                                                      Grid.ColumnSpan="3"
                                                      Panel.ZIndex="5"
                                                      Visibility="Collapsed"
                                                      IsHitTestVisible="False">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="PdfSplitDropLeft"
                                                            Grid.Column="0"
                                                            Margin="6"
                                                            CornerRadius="10"
                                                            BorderThickness="2"
                                                            Opacity="0.35"
                                                            BorderBrush="{DynamicResource StrokeBrush}"
                                                            Background="{DynamicResource SelectedBrush}"/>
                                                    <Border x:Name="PdfSplitDropRight"
                                                            Grid.Column="1"
                                                            Margin="6"
                                                            CornerRadius="10"
                                                            BorderThickness="2"
                                                            Opacity="0.35"
                                                            BorderBrush="{DynamicResource StrokeBrush}"
                                                            Background="{DynamicResource SelectedBrush}"/>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="EstimateTab" Header="Сметы" Style="{StaticResource HiddenPinnedTabItemStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="EstimateTreeHoverColumn" Width="28"/>
                                        <ColumnDefinition x:Name="EstimateTreeColumn" Width="320"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="EstimateTreeHoverStrip"
                                            Grid.Column="0"
                                            Background="{DynamicResource SelectedBrush}"
                                            BorderBrush="{DynamicResource StrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,4,0"
                                            MouseEnter="EstimateTreeHoverZone_MouseEnter">
                                        <Grid>
                                            <TextBlock Text="Дерево смет"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.LayoutTransform>
                                                    <RotateTransform Angle="-90"/>
                                                </TextBlock.LayoutTransform>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="EstimateTreePanelBorder"
                                            Grid.Column="1"
                                            Style="{StaticResource CardBorderStyle}"
                                            Margin="0,0,12,0"
                                            MouseEnter="EstimateTreePanel_MouseEnter"
                                            MouseLeave="EstimateTreePanel_MouseLeave">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Content="⋯"
                                                        Width="32"
                                                        Height="24"
                                                        Padding="0"
                                                        FontSize="16"
                                                        Style="{StaticResource SecondaryButton}"
                                                        ToolTip="Действия со сметами"
                                                        Click="EstimateActionsMenuButton_Click">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Выбрать сметы" Click="AddEstimateFiles_Click"/>
                                                            <MenuItem Header="Новая папка" Click="AddEstimateFolder_Click"/>
                                                            <MenuItem Header="Переименовать" Click="RenameEstimateNode_Click"/>
                                                            <MenuItem Header="Удалить" Click="DeleteEstimateNode_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Вверх" Click="MoveEstimateNodeUp_Click"/>
                                                            <MenuItem Header="Вниз" Click="MoveEstimateNodeDown_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Поиск по дереву..." Click="SearchEstimateNodes_Click"/>
                                                            <MenuItem Header="Пакетное переименование..." Click="BatchRenameEstimateNodes_Click"/>
                                                            <MenuItem Header="Реорганизовать по типам" Click="ReorganizeEstimateNodes_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Открыть" Click="OpenEstimateNode_Click"/>
                                                            <MenuItem Header="Отчет по документам" Click="OpenEstimateLibraryReport_Click"/>
                                                            <MenuItem Header="Сводный отчет по всем документам" Click="OpenAllDocumentsReport_Click"/>
                                                            <MenuItem Header="Проверка целостности документов" Click="CheckEstimateDocumentsIntegrity_Click"/>
                                                            <MenuItem Header="Обслуживание хранилища документов" Click="RunDocumentStorageMaintenance_Click"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>

                                                <ToggleButton x:Name="EstimateTreePinToggle"
                                                              Grid.Column="2"
                                                              Width="24"
                                                              Height="24"
                                                              HorizontalAlignment="Right"
                                                              VerticalAlignment="Top"
                                                              Margin="0"
                                                              ToolTip="Закрепить дерево смет"
                                                              Checked="EstimateTreePinToggle_Checked"
                                                              Unchecked="EstimateTreePinToggle_Unchecked">📎</ToggleButton>
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox x:Name="EstimateTreeSearchBox"
                                                         Grid.Column="0"
                                                         Height="28"
                                                         Margin="0,0,6,0"
                                                         Padding="8,0"
                                                         VerticalContentAlignment="Center"
                                                         ToolTip="Поиск по сметам"
                                                         KeyDown="EstimateTreeSearchBox_KeyDown"/>
                                                <Button Grid.Column="1"
                                                        Content="Найти"
                                                        Height="28"
                                                        MinWidth="72"
                                                        Margin="0,0,6,0"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="EstimateTreeSearchButton_Click"/>
                                                <Button Grid.Column="2"
                                                        Content="Очистить"
                                                        Height="28"
                                                        MinWidth="86"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Click="EstimateTreeSearchClear_Click"/>
                                            </Grid>

                                            <TreeView x:Name="EstimateTreeView"
                                                      Grid.Row="2"
                                                      AllowDrop="True"
                                                      SelectedItemChanged="EstimateTreeView_SelectedItemChanged"
                                                      PreviewMouseLeftButtonDown="EstimateTreeView_PreviewMouseLeftButtonDown"
                                                      MouseMove="EstimateTreeView_MouseMove"
                                                      Drop="EstimateTreeView_Drop">
                                                <TreeView.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </HierarchicalDataTemplate>
                                                </TreeView.ItemTemplate>
                                            </TreeView>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Padding="0"
                                            Style="{StaticResource CardBorderStyle}"
                                            CornerRadius="0"
                                            MouseEnter="EstimatePreviewArea_MouseEnter">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0"
                                                  Margin="10,8,10,6"
                                                  Visibility="Collapsed"
                                                  Height="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ListBox x:Name="EstimateTabStrip"
                                                         Grid.Column="0"
                                                         Height="32"
                                                         Margin="0,0,8,0"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Visibility="Collapsed"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                         SelectionChanged="EstimateTabStrip_SelectionChanged"
                                                         PreviewMouseLeftButtonDown="EstimateTabStrip_PreviewMouseLeftButtonDown"
                                                         MouseMove="EstimateTabStrip_MouseMove"
                                                         AllowDrop="True"
                                                         Drop="EstimateTabStrip_Drop">
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,6,0"
                                                                    Padding="8,4"
                                                                    CornerRadius="10"
                                                                    Background="{DynamicResource SurfaceAltBrush}"
                                                                    BorderBrush="{DynamicResource StrokeBrush}"
                                                                    BorderThickness="1">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Margin="0,0,6,0"
                                                                               VerticalAlignment="Center"/>
                                                                    <Button Content="×"
                                                                            Width="10"
                                                                            Height="10"
                                                                            Padding="0"
                                                                            Margin="2,0,0,0"
                                                                            MinWidth="10"
                                                                            FontSize="8"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Tag="{Binding}"
                                                                            Click="EstimateTabClose_Click"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <TextBlock Grid.Column="1"
                                                           Margin="0"
                                                           Visibility="Collapsed"/>
                                                <TextBlock Grid.Column="2"
                                                           Margin="0"
                                                           Visibility="Collapsed"/>
                                            </Grid>

                                            <Grid Grid.Row="1" x:Name="EstimateSplitGrid"
                                                  AllowDrop="True"
                                                  DragEnter="EstimateSplitGrid_DragEnter"
                                                  DragLeave="EstimateSplitGrid_DragLeave"
                                                  DragOver="EstimateSplitGrid_DragOver"
                                                  Drop="EstimateSplitGrid_Drop">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition x:Name="EstimateSplitPrimaryColumn" Width="*"/>
                                                    <ColumnDefinition x:Name="EstimateSplitDividerColumn" Width="6"/>
                                                    <ColumnDefinition x:Name="EstimateSplitSecondaryColumn" Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="EstimatePrimaryPane" Grid.Column="0">
                                                    <Grid>
                                                        <StackPanel x:Name="EstimateInfoPanel"
                                                                    Margin="14">
                                                            <TextBlock Text="Сметы" FontSize="20" FontWeight="SemiBold"/>
                                                            <TextBlock Text="Выберите файлы смет и соберите для них свою структуру дерева. Можно создавать папки, переименовывать узлы и перемещать их мышкой."
                                                                       Margin="0,8,0,16"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="Выбранный узел" FontWeight="SemiBold"/>
                                                            <TextBlock x:Name="EstimateSelectedNameText"
                                                                       Margin="0,6,0,10"
                                                                       FontSize="16"
                                                                       Text="Ничего не выбрано"/>
                                                            <TextBlock Text="Путь к файлу" FontWeight="SemiBold"/>
                                                            <TextBlock x:Name="EstimateSelectedPathText"
                                                                       Margin="0,6,0,10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Text="—"/>
                                                            <TextBlock Text="Тип узла" FontWeight="SemiBold"/>
                                                            <TextBlock x:Name="EstimateSelectedTypeText"
                                                                       Margin="0,6,0,0"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       Text="—"/>
                                                        </StackPanel>

                                                        <Border x:Name="EstimatePreviewContainer"
                                                                Background="{DynamicResource SurfaceBrush}"
                                                                BorderThickness="0"
                                                                CornerRadius="0"
                                                                Padding="0"
                                                                Margin="0"
                                                                SizeChanged="EstimatePreviewContainer_SizeChanged"
                                                                Visibility="Collapsed">
                                                            <Grid>
                                                                <local:NativeChildHost x:Name="EstimateExcelHost"
                                                                                       Visibility="Collapsed"/>
                                                                <WebBrowser x:Name="EstimatePreviewBrowser"
                                                                            Visibility="Collapsed"/>
                                                                <Border x:Name="EstimatePreviewPlaceholder"
                                                                        Background="Transparent">
                                                                    <StackPanel HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center"
                                                                                MaxWidth="420">
                                                                        <TextBlock Text="Предпросмотр"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="18"
                                                                                   HorizontalAlignment="Center"/>
                                                                        <TextBlock x:Name="EstimatePreviewStatusText"
                                                                                   Margin="0,10,0,0"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   TextAlignment="Center"
                                                                                   TextWrapping="Wrap"
                                                                                   Text="Выберите файл сметы в дереве слева, и он откроется здесь."/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <GridSplitter x:Name="EstimateSplitBar"
                                                              Grid.Column="1"
                                                              Width="6"
                                                              Background="{DynamicResource StrokeBrush}"
                                                              HorizontalAlignment="Stretch"
                                                              VerticalAlignment="Stretch"
                                                              Visibility="Collapsed"/>

                                                <Border x:Name="EstimatePreviewContainerSecondary"
                                                        Grid.Column="2"
                                                        BorderBrush="{DynamicResource StrokeBrush}"
                                                        BorderThickness="1"
                                                        Background="{DynamicResource SurfaceAltBrush}"
                                                        Visibility="Collapsed"
                                                        SizeChanged="EstimatePreviewContainerSecondary_SizeChanged"
                                                        AllowDrop="True"
                                                        Drop="EstimateSecondaryPane_Drop">
                                                    <Grid>
                                                        <Border x:Name="EstimatePreviewPlaceholderSecondary"
                                                                Background="Transparent">
                                                            <StackPanel HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        MaxWidth="420">
                                                                <TextBlock Text="Второй файл"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="16"
                                                                           HorizontalAlignment="Center"/>
                                                                <TextBlock x:Name="EstimatePreviewStatusTextSecondary"
                                                                           Margin="0,10,0,0"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap"
                                                                           Text="Перетащите вкладку сюда для открытия рядом."/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <Grid x:Name="EstimateSplitDropOverlay"
                                                      Grid.ColumnSpan="3"
                                                      Panel.ZIndex="5"
                                                      Visibility="Collapsed"
                                                      IsHitTestVisible="False">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border x:Name="EstimateSplitDropLeft"
                                                            Grid.Column="0"
                                                            Margin="6"
                                                            CornerRadius="10"
                                                            BorderThickness="2"
                                                            Opacity="0.35"
                                                            BorderBrush="{DynamicResource StrokeBrush}"
                                                            Background="{DynamicResource SelectedBrush}"/>
                                                    <Border x:Name="EstimateSplitDropRight"
                                                            Grid.Column="1"
                                                            Margin="6"
                                                            CornerRadius="10"
                                                            BorderThickness="2"
                                                            Opacity="0.35"
                                                            BorderBrush="{DynamicResource StrokeBrush}"
                                                            Background="{DynamicResource SelectedBrush}"/>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>



                    </TabControl>
                </Grid>
              </Border>
        </Grid>
        </DockPanel>

        <Grid x:Name="ProcessingOverlay"
              Visibility="Collapsed"
              Panel.ZIndex="999"
              Background="{DynamicResource OverlayBrush}">
            <Border Width="300"
                    Padding="16"
                    CornerRadius="12"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource StrokeBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock x:Name="ProcessingOverlayText"
                               Text="Идет обработка..."
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <ProgressBar Height="8"
                                 IsIndeterminate="True"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
