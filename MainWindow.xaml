                                                              IsTextSearchEnabled="True"
                                                              StaysOpenOnEdit="True"
                                                              ItemsSource="{Binding ElementName=RootWindow, Path=Specialties}"/>
                                                    <ComboBox x:Name="TimesheetWorkModeComboBox"
                                                              Width="160"
                                                              Style="{StaticResource TimesheetToolbarFieldComboBox}"
                                                              SelectedIndex="0"
                                                              Tag="Режим работы">
                                                        <ComboBoxItem Content="Обычно (8 ч)"/>
                                                        <ComboBoxItem Content="Вахта (12 ч)"/>
                                                    </ComboBox>
