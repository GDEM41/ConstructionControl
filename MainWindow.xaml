                                                                  Checked="JournalToolsPinToggle_Checked"
                                                                  Unchecked="JournalToolsPinToggle_Unchecked"
                                                                  Tag="Timesheet"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
