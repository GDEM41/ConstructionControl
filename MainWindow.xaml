                                    <Grid x:Name="JvkHeaderGrid">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="260"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="260"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                BorderBrush="{DynamicResource StrokeBrush}"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="ттн"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="1"
                                                BorderBrush="{DynamicResource StrokeBrush}"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="название"
                                                           FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="2"
                                                BorderBrush="{DynamicResource StrokeBrush}"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="стб"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="3"
                                                BorderBrush="{DynamicResource StrokeBrush}"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="ед.изм"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="4"
                                                BorderBrush="{DynamicResource StrokeBrush}"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="кол-во"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="5"
                                                BorderBrush="{DynamicResource StrokeBrush}"
                                                BorderThickness="0,0,1,0"
                                                Padding="6,4">
                                            <TextBlock Text="поставщик"
                                                        FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="6"
                                                Padding="6,4">
                                            <TextBlock Text="паспорт"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto"
                                              Margin="0,4,0,0">
                                    <StackPanel x:Name="JvkPanel"/>
                                </ScrollViewer>
                            </Grid>


                        </Grid>
                        <!-- ← ВАЖНО -->
                    </TabItem>



                    <TabItem x:Name="ArrivalTab" Header="Приход">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- ====== КНОПКА ДОБАВИТЬ ПРИХОД ====== -->
                            <!-- ====== КНОПКИ ПРИХОДА ====== -->
                            <WrapPanel Orientation="Horizontal"
                                       Grid.Row="0"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,10"
                                       Panel.ZIndex="1">

                                <!-- 🔍 Локальный поиск -->
                                <TextBox x:Name="ArrivalSearchBox"
                                         Width="260"
                                         Height="32"
                                         Tag="Поиск: материал или ТТН"
                                         VerticalContentAlignment="Center"
                                         FontSize="13"
                                         Margin="0,0,10,0"
                                         ToolTip="Поиск: наименование / ТТН"
                                         TextChanged="ArrivalSearchBox_TextChanged"/>

                                <!-- Кнопка фильтры -->
                                <Button x:Name="ArrivalFilterButton"
                                        Content="Фильтры"
                                        Width="130"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Click="ArrivalFilterButton_Click"/>

                                <Button x:Name="ArrivalLegacyViewButton"
                                        Content="Таблица"
                                        Width="120"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Click="ArrivalLegacyViewButton_Click"/>

                                <Button x:Name="ArrivalMatrixViewButton"
                                        Content="Матрица"
                                        Width="120"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Click="ArrivalMatrixViewButton_Click"/>

                                <ComboBox x:Name="ArrivalTemplateBox"
                                          Width="190"
                                          Height="34"
                                          Margin="0,0,10,0"
                                          Tag="Шаблоны фильтра"
                                          Visibility="Collapsed"
                                          SelectionChanged="ArrivalTemplateBox_SelectionChanged"/>

                                <Button x:Name="SaveArrivalTemplateButton"
                                        Content="★ Шаблон"
                                        Width="120"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        Click="SaveArrivalFilterTemplate_Click"/>

                                <Button x:Name="DeleteArrivalTemplateButton"
                                        Content="Удалить шаблон"
                                        Width="140"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Visibility="Collapsed"
                                        Click="DeleteArrivalFilterTemplate_Click"/>

                                <Button x:Name="BatchEditArrivalButton"
                                        Content="Пакетно изменить"
                                        Width="150"
                                        Height="34"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource SecondaryButton}"
                                        Click="BatchEditArrivalRows_Click"/>

                                <Button Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,10,0"
                                        Click="ExportArrival_Click">
                                    ⬇ Экспорт
                                </Button>


                                <!-- Кнопка добавления -->
                                <Button x:Name="ShowArrivalButton"
                                        Content="➕ Добавить приход"
                                        Width="200"
                                        Height="34"
                                        Click="ShowArrivalButton_Click"/>
                            </WrapPanel>



                            <Border Grid.Row="1"
                                    Margin="0"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource StrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <Grid>
                                    <ScrollViewer x:Name="ArrivalMatrixScrollViewer"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <Grid x:Name="ArrivalMatrixHost"/>
                                    </ScrollViewer>

                                    <DataGrid x:Name="ArrivalLegacyGrid"
                                              Visibility="Collapsed"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserResizeColumns="True"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              GridLinesVisibility="All"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              BorderThickness="0"
                                              RowBackground="{DynamicResource SurfaceBrush}"
                                              AlternatingRowBackground="{DynamicResource SurfaceAltBrush}"
                                              VerticalGridLinesBrush="{DynamicResource DividerBrush}"
                                              HorizontalGridLinesBrush="{DynamicResource DividerBrush}"
                                              RowStyle="{StaticResource ArrivalAnomalyRowStyle}"
                                              CellEditEnding="ArrivalLegacyGrid_CellEditEnding"
                                              RowEditEnding="ArrivalLegacyGrid_RowEditEnding">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Дата"
                                                                Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                                                Width="95"/>
                                            <DataGridTextColumn Header="Категория"
                                                                Binding="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="110"/>
                                            <DataGridTextColumn Header="Тип"
                                                                Binding="{Binding MaterialGroup, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="150"/>
                                            <DataGridTextColumn Header="Наименование"
                                                                Binding="{Binding MaterialName, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="240"/>
                                            <DataGridTextColumn Header="Количество"
                                                                Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="95"/>
                                            <DataGridTextColumn Header="Ед."
                                                                Binding="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="70"/>
                                            <DataGridTextColumn Header="Паспорт"
                                                                Binding="{Binding Passport, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="130"/>
                                            <DataGridTextColumn Header="СТБ"
                                                                Binding="{Binding Stb, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="90"/>
                                            <DataGridTextColumn Header="Поставщик"
                                                                Binding="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="170"/>
                                            <DataGridTextColumn Header="ТТН"
                                                                Binding="{Binding Ttn, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="140"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <!-- ====== ОВЕРЛЕЙ ФИЛЬТРОВ ПРИХОДА ====== -->
                            <!-- ====== ОВЕРЛЕЙ ФИЛЬТРОВ ПРИХОДА ====== -->
                            <Grid x:Name="ArrivalFiltersOverlay"
                                  Visibility="Collapsed"
                                  Background="{DynamicResource OverlayBrush}"
                                  Panel.ZIndex="50"
                                  Grid.RowSpan="2">

                                <Border Background="{DynamicResource SurfaceBrush}"
            Padding="20"
            CornerRadius="10"
            Width="450"
            MinHeight="450"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                                    <StackPanel>

                                        <!-- Кнопка закрыть -->
                                        <Button Content="✖"
                    HorizontalAlignment="Right"
                    Width="28"
                    Height="28"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="14"
                    Click="CloseArrivalFilters_Click"/>

                                        <TextBlock Text="Фильтры прихода"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Margin="0,0,0,16"/>

                                        <!-- ====== ТИПЫ (ГРУППЫ) ====== -->
                                        <TextBlock Text="Тип материалов"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

                                        <WrapPanel x:Name="ArrivalTypesPanel"
                       Margin="0,6,0,10"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Width="400"/>

                                        <!-- ====== КАТЕГОРИЯ ====== -->
                                        <TextBlock Text="Категория"
                       FontWeight="SemiBold"
                       Margin="0,10,0,6"/>

                                        <StackPanel>
                                            <CheckBox x:Name="ArrivalMainCheck"
                          Content="Основные"
                          IsChecked="True"
                          Checked="ArrivalFilters_Changed"
                          Unchecked="ArrivalFilters_Changed"/>

                                            <CheckBox x:Name="ArrivalExtraCheck"
                          Content="Малоценка"
                          IsChecked="True"
                          Checked="ArrivalFilters_Changed"
                          Unchecked="ArrivalFilters_Changed"/>

                                            <CheckBox x:Name="ArrivalLowCostCheck"
                              Content="Внутренние"
                              IsChecked="True"
                              Checked="ArrivalFilters_Changed"
                              Unchecked="ArrivalFilters_Changed"/>
                                        </StackPanel>

                                        <!-- ====== НАИМЕНОВАНИЕ ====== -->
                                        <TextBlock Text="Наименование"
                       FontWeight="SemiBold"
                       Margin="0,12,0,6"/>

                                        <ScrollViewer Height="180"
                          VerticalScrollBarVisibility="Auto">
                                            <WrapPanel x:Name="ArrivalNamesPanel"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Width="400"/>
                                        </ScrollViewer>

                                        <!-- ====== ПЕРИОД ====== -->
                                        <TextBlock Text="Период"
                       FontWeight="SemiBold"
                       Margin="0,12,0,4"/>

                                        <Grid Width="404">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <DatePicker x:Name="ArrivalDateFrom"
                                                        Grid.Column="0"
                                                        Style="{StaticResource ArrivalFilterDatePicker}"
                                                        SelectedDateFormat="Short"
                                                        SelectedDateChanged="ArrivalFilters_Changed"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="—"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="16"/>

                                            <DatePicker x:Name="ArrivalDateTo"
                                                        Grid.Column="2"
                                                        Style="{StaticResource ArrivalFilterDatePicker}"
                                                        SelectedDateFormat="Short"
                                                        SelectedDateChanged="ArrivalFilters_Changed"/>
                                        </Grid>


                                        <!-- ====== КНОПКИ ====== -->
                                        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,20,0,0">

                                            <Button Content="🔄 Сбросить фильтры"
            Width="160"
            Height="34"
            Padding="10,0"
            Background="{DynamicResource SecondaryBrush}"
            BorderBrush="{DynamicResource StrokeBrush}"
            Foreground="{DynamicResource TextSecondaryBrush}"
            FontSize="13"
            FontWeight="SemiBold"
            Click="ArrivalClearFilters_Click"/>
                                        </StackPanel>



                                    </StackPanel>

                                </Border>
                            </Grid>



                            <!-- ====== ПАНЕЛЬ ДОБАВЛЕНИЯ (ОКНО СВЕРХУ) ====== -->
                            <Border x:Name="ArrivalPopup"
                                    Background="{DynamicResource OverlayStrongBrush}"
                                    Visibility="Collapsed"
                                    Panel.ZIndex="10"
                                    Grid.RowSpan="2">
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="6"
                        Padding="10"
                        Width="1320" MinHeight="520">

                                        <StackPanel>
                                            <local:ArrivalControl x:Name="ArrivalPanel"/>

                                            <Button Content="✖ Закрыть"
                                                               HorizontalAlignment="Right"
                                                               Width="120"
                                                               Height="32"
                                                               Margin="0,10,0,0"
                                                               Click="HideArrivalButton_Click"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                        </Grid>
                    </TabItem>
                        <TabItem x:Name="OtTab" Header="ОТ">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border x:Name="OtToolsHoverStrip"
                                    Grid.Row="0"
                                    Style="{StaticResource AutoHidePanelHoverStripStyle}"
                                    MouseEnter="JournalToolsHoverStrip_MouseEnter"
                                    ToolTip="Наведите курсор, чтобы развернуть панель"
                                    Tag="Ot">
                                <TextBlock Text="Панель ОТ (наведите курсор, чтобы развернуть)"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>

                            <Border x:Name="OtToolsPanelBorder"
                                    Grid.Row="1"
                                    Style="{StaticResource CardBorderStyle}"
                                    Margin="0,0,0,10"
                                    Visibility="Collapsed"
                                    MouseEnter="JournalToolsPanel_MouseEnter"
                                    MouseLeave="JournalToolsPanel_MouseLeave"
                                    Tag="Ot">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                        <Grid Grid.Row="0"
                                              Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="360"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <WrapPanel Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0">
                                                <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ComboBox x:Name="OtStatusFilterBox"
                                                          Width="170"
                                                          Margin="0,0,12,0"
                                                          SelectionChanged="OtFilters_SelectionChanged"/>
                                                <TextBlock Text="Специальность:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ComboBox x:Name="OtSpecialtyFilterBox"
                                                          Width="220"
                                                          Margin="0,0,12,0"
                                                          SelectionChanged="OtFilters_SelectionChanged"/>
                                                <TextBlock Text="Бригада:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ComboBox x:Name="OtBrigadeFilterBox"
                                                          Width="200"
                                                          SelectionChanged="OtFilters_SelectionChanged"/>
                                            </WrapPanel>

                                            <TextBox x:Name="OtSearchTextBox"
                                                     Grid.Column="1"
                                                     Margin="0"
                                                     VerticalAlignment="Center"
                                                     Tag="Поиск по ФИО, например: Иванов"
                                                     TextChanged="OtSearchTextBox_TextChanged"/>

                                            <ToggleButton x:Name="OtToolsPinToggle"
                                                          Grid.Column="2"
                                                          Style="{StaticResource AutoHidePanelPinToggleStyle}"
                                                          Margin="12,0,0,0"
                                                          VerticalAlignment="Top"
                                                          ToolTip="Закрепить панель ОТ"
                                                          Checked="JournalToolsPinToggle_Checked"
                                                          Unchecked="JournalToolsPinToggle_Unchecked"
                                                          Tag="Ot"/>
                                        </Grid>

                                    <ScrollViewer Grid.Row="1"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  CanContentScroll="False">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource PrimaryButton}" Click="AddOtRow_Click">➕ Добавить запись</Button>
                                            <Button Style="{StaticResource SecondaryButton}" Click="MarkSelectedRepeatDone_Click" Margin="8,0,0,0">✅ Отметить инструктаж</Button>
                                            <Button Style="{StaticResource SecondaryButton}" Click="MarkSelectedPersonDismissed_Click" Margin="8,0,0,0">🚫 Снять с объекта</Button>
                                            <Button Style="{StaticResource SecondaryButton}" Click="OpenOtPersonHistory_Click" Margin="8,0,0,0">🕘 История сотрудника</Button>
                                            <Button Style="{StaticResource SecondaryButton}" Click="OpenTodayActionsReport_Click" Margin="8,0,0,0">📌 Действия на сегодня</Button>
                                            <Button Style="{StaticResource SecondaryButton}" Click="DeleteSelectedOtRow_Click" Margin="8,0,0,0">🗑 Удалить запись</Button>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                                <WrapPanel>
                                    <Border Background="{DynamicResource WarningSoftBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="Желтый: требуется инструктаж"/>
                                    </Border>
                                    <Border Background="{DynamicResource SuccessSoftBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="Зеленый: инструктаж пройден"/>
                                    </Border>
                                    <Border Background="{DynamicResource SelectedBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                        <TextBlock Text="Синий: запланирован следующий повторный"/>
                                    </Border>
                                    <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4">
                                        <TextBlock Text="Серый: снят с объекта"/>
                                    </Border>
                                </WrapPanel>
                            </Border>

                            <DataGrid x:Name="OtJournalGrid"
                                      Grid.Row="3"
                                      AutoGenerateColumns="False"
                                      ColumnWidth="Auto"
                                        CanUserResizeColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="True"
                                      MinRowHeight="42"
                                      RowStyle="{StaticResource OtDueRowStyle}"
                                      RowEditEnding="OtJournalGrid_RowEditEnding"
                                      CellEditEnding="OtJournalGrid_CellEditEnding"
                                      PreviewKeyDown="OtJournalGrid_PreviewKeyDown">
                                <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Дата" Width="115">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding InstructionDate, StringFormat=dd.MM.yyyy}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <DatePicker SelectedDate="{Binding InstructionDate, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="ФИО" Width="230">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                    <TextBlock Text="{Binding FullNameDisplay}" TextWrapping="Wrap"/>
                                                </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                            <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                                         Tag="Фамилия Имя Отчество"
                                                        
                                                         TextWrapping="Wrap"
                                                         VerticalContentAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="Специальность" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Specialty}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox IsEditable="False"
                                                          IsTextSearchEnabled="True"
                                                          ItemsSource="{Binding ElementName=RootWindow, Path=Specialties}"
                                                          SelectedItem="{Binding Specialty, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="Разряд" Binding="{Binding Rank, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
