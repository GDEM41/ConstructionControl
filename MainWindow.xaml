<Window x:Class="ConstructionControl.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConstructionControl"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        Title="Журнал входного контроля"
        Height="700"
        Width="1300"
        Background="#F6F7FB"
         Loaded="MainWindow_Loaded"
        Closed="MainWindow_Closed">

    <!-- ================= СТИЛИ ================= -->
    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="ReminderActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#1D4ED8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
                        <Style x:Key="ChipToggle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,4,4,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="root"
                        CornerRadius="6"
                        BorderThickness="1"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#1C7C54"/>
                                <Setter TargetName="root" Property="BorderBrush" Value="#176746"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SummaryFilterToggle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"/>
                                <Border x:Name="ArrowBg"
                                        Grid.Column="1"
                                        Width="28"
                                        Height="28"
                                        CornerRadius="6"
                                        Background="#F3F4F6"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="▾"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#6B7280"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
                                <Setter TargetName="ArrowBg" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#9CCBB3"/>
                                <Setter TargetName="Bd" Property="Background" Value="#EEF7F1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SummaryFilterRadio" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="#F3F4F6"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10,6">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C7C54"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#176746"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernSummaryActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#2F80ED"/>
            <Setter Property="BorderBrush" Value="#256FD0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#256FD0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E5CAD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSummaryModeToggle" TargetType="CheckBox">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="#EEF7F1"/>
            <Setter Property="BorderBrush" Value="#B9D8C6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Bd" CornerRadius="10" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C7C54"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#176746"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- Кнопка основная -->


        <!-- Кнопка вторичная -->
        <Style x:Key="SecondaryButton" TargetType="Button"
               BasedOn="{StaticResource AppSecondaryButton}">
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <!-- Toolbar кнопка -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#5AA9FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5AA9FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <Style x:Key="IconToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#5AA9FF"/>
            <Setter Property="BorderBrush" Value="#5AA9FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" Opacity="0.14" ShadowDepth="2" Color="#1B365A"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#439AFF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#439AFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3189F2"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3189F2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#94C8FF"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#94C8FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OtDueRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPendingRepeat}" Value="True">
                    <Setter Property="Background" Value="#FFF7C2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRepeatCompleted}" Value="True">
                    <Setter Property="Background" Value="#DCFCE7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MainTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="#526173"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E3EAF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                MinWidth="{TemplateBinding MinWidth}"
                                MinHeight="{TemplateBinding MinHeight}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect x:Name="TabShadow" BlurRadius="6" Opacity="0.035" ShadowDepth="1" Color="#19324F"/>
                            </Border.Effect>
                            <ContentPresenter x:Name="ContentSite"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF4FB"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C7D8EC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#244263"/>
                                <Setter TargetName="Root" Property="Background" Value="#E7F0FB"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#BED3EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PinnedRightTabButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#526173"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E3EAF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF4FB"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C7D8EC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DCEBFA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HiddenPinnedTabItemStyle" TargetType="TabItem">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Width" Value="0"/>
            <Setter Property="Height" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid Width="0" Height="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



    </Window.Resources>

    <Grid x:Name="MainRootGrid">
        <DockPanel>

            <!-- ================= МЕНЮ ================= -->
        <Menu DockPanel.Dock="Top"
              Background="White"
              BorderThickness="0">
            <MenuItem Header="Создать" Click="CreateObject_Click"/>
            <MenuItem Header="Архив" Click="OpenArchive_Click" />

            <MenuItem Header="Сохранить как" Click="SaveAs_Click"/>
            <MenuItem Header="Настройки объекта" Click="ObjectSettings_Click"/>
                <MenuItem Header="База материалов" Click="TreeSettings_Click"/>
                <MenuItem Header="Обмен данными">
                    <MenuItem Header="Импорт Excel" Click="ImportExcel_Click"/>
                    <MenuItem Header="Экспорт всего" Click="ExportAllData_Click"/>
                    <MenuItem Header="Импорт всего" Click="ImportAllData_Click"/>
                </MenuItem>
                <MenuItem Header="Настройки" Click="AppSettings_Click"/>
                <MenuItem Header="Выход" Click="Exit_Click"/>
        </Menu>

        <!-- ================= TOOLBAR ================= -->
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                Padding="6">

            <ToolBar Background="Transparent">

                <Button Style="{StaticResource IconButton}"
                        ToolTip="Сохранить"
                        Click="SaveButton_Click">
                    💾
                </Button>

                <ToggleButton Style="{StaticResource IconToggle}"
              ToolTip="Блокировка"
              IsChecked="True"
              Checked="LockToggle_Checked"
              Unchecked="LockToggle_Unchecked">
                    🔒
                </ToggleButton>



                <Separator Margin="6,0"/>

                <Button x:Name="UndoButton"
        Style="{StaticResource IconButton}"
        Click="Undo_Click"
        IsEnabled="False">
                    ↩

                </Button>

                <Button x:Name="RedoButton"
        Style="{StaticResource IconButton}"
        Click="Redo_Click"
        IsEnabled="False">
                    ↪
                </Button>
                
                    <Separator Margin="6,0"/>
                
                    <Button Style="{StaticResource IconButton}"
                        ToolTip="Обновить"
                        Click="RefreshButton_Click">⟳</Button>
                    <Separator Margin="10,0"/>

                </ToolBar>
        </Border>

        <!-- ================= ОСНОВНАЯ ОБЛАСТЬ ================= -->
        <Grid Margin="10">

            <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="TreeHoverColumn" Width="28"/>
                    <ColumnDefinition x:Name="TreeColumn" Width="260"/>
                    <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
                <Border x:Name="TreeHoverStrip"
                    Grid.Column="0"
                    Background="#EEF4FB"
                    BorderBrush="#D6E2F0"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,4,0"
                    MouseEnter="TreeHoverZone_MouseEnter">
                    <Grid>
                        <TextBlock Text="Дерево материалов"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#526173"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- ===== ДЕРЕВО ===== -->
                <Border x:Name="TreePanelBorder"
                    Grid.Column="1"
                    Background="White"
                    CornerRadius="8"
                    Padding="6"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    MouseEnter="TreePanel_MouseEnter"
                    MouseLeave="TreePanel_MouseLeave">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ToggleButton x:Name="TreePinToggle"
                                  Width="24"
                                  Height="24"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top"
                                  Margin="0,0,0,6"
                                  ToolTip="Закрепить панель дерева"
                                  Checked="TreePinToggle_Checked"
                                  Unchecked="TreePinToggle_Unchecked">📎</ToggleButton>

                        <TreeView x:Name="ObjectsTree"
                              Grid.Row="1"
                              AllowDrop="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              SelectedItemChanged="ObjectsTree_SelectedItemChanged"
                              PreviewMouseLeftButtonDown="ObjectsTree_PreviewMouseLeftButtonDown"
                              MouseMove="ObjectsTree_MouseMove"
                              Drop="ObjectsTree_Drop">

                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Переименовать"
                                          Click="RenameTreeItem_Click"/>
                                    <MenuItem Header="Удалить"
                                          Click="DeleteTreeItem_Click"/>
                                </ContextMenu>
                            </TreeView.ContextMenu>
                        </TreeView>
                    </Grid>
                </Border>

            <!-- ===== КОНТЕНТ ===== -->
                <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="8"
                    Padding="8"
                    Margin="10,0,0,0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    MouseEnter="ContentPanel_MouseEnter">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FFFFFF"
                            BorderBrush="#E8EEF5"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="4"
                            Margin="0,0,0,8">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.06" ShadowDepth="2" Color="#19324F"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="SummaryTabButton"
                                        Content="Сводка"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="SummaryTabButton_Click"/>
                                <Button x:Name="JvkTabButton"
                                        Content="ЖВК"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="JvkTabButton_Click"/>
                                <Button x:Name="ArrivalTabButton"
                                        Content="Приход"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="ArrivalTabButton_Click"/>
                                <Button x:Name="OtTabButton"
                                        Content="ОТ"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="OtTabButton_Click"/>
                                <Button x:Name="TimesheetTabButton"
                                        Content="Табель"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="TimesheetTabButton_Click"/>
                                <Button x:Name="ProductionTabButton"
                                        Content="ПР"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="ProductionTabButton_Click"/>
                                <Button x:Name="InspectionTabButton"
                                        Content="Осмотры"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="InspectionTabButton_Click"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="PdfPinnedTabButton"
                                        Content="ПДФ"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Click="PdfPinnedTabButton_Click"/>
                                <Button x:Name="EstimatePinnedTabButton"
                                        Content="Сметы"
                                        Style="{StaticResource PinnedRightTabButtonStyle}"
                                        Margin="0"
                                        Click="EstimatePinnedTabButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl x:Name="MainTabs"
             Grid.Row="1"
             BorderThickness="0"
             Style="{StaticResource MainTabControlStyle}"
             ItemContainerStyle="{StaticResource HiddenPinnedTabItemStyle}"
             SelectionChanged="TabControl_SelectionChanged">


                    <!-- ===== СВОДНАЯ ===== -->
                        <TabItem x:Name="SummaryTab" Header="Сводка">
                            <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Margin="0,0,0,8">
                                    <WrapPanel VerticalAlignment="Center">
                                        <Grid Width="260" Margin="0,0,10,6">
                                            <ToggleButton x:Name="SummaryFilterButton"
                                                      Style="{StaticResource SummaryFilterToggle}"
                                                      HorizontalContentAlignment="Left">
                                                <StackPanel>
                                                    <TextBlock Text="Фильтр типов" FontWeight="SemiBold" Foreground="#111827"/>
                                                    <TextBlock x:Name="SummaryFilterSubtitle" Text="Нет доступных типов" Foreground="#6B7280" FontSize="12"/>

                                                </StackPanel>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=SummaryFilterButton}" IsOpen="{Binding IsChecked, ElementName=SummaryFilterButton}" PopupAnimation="Fade" AllowsTransparency="True" StaysOpen="False">
                                                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Padding="12" MinWidth="260">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/>
                                                    </Border.Effect>
                                                    <StackPanel>
                                                        <TextBlock Text="Показывать в сводке" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"/>
                                                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                            <StackPanel x:Name="SummaryTypeFilterPanel"/>
                                                        </ScrollViewer>
                                                        <Separator Margin="0,8,0,8"/>
                                                        <TextBlock Text="Подтип" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,6"/>
                                                        <StackPanel x:Name="SummarySubTypeFilterPanel"/>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="8" Margin="0,0,0,6">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Потребность по отметкам" Style="{StaticResource ModernSummaryActionButton}" Click="OpenDemandEditor_Click"/>
                                                <Button Content="Дозаказать" Style="{StaticResource ModernSummaryActionButton}" Margin="8,0,0,0" Click="OpenReorderWindow_Click"/>
                                                <CheckBox x:Name="SummaryMountedModeSwitch" Content="Режим монтажа" Style="{StaticResource ModernSummaryModeToggle}" Checked="SummaryModeSwitch_Changed" Unchecked="SummaryModeSwitch_Changed"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            <ListBox x:Name="SummaryPanel"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                          ScrollViewer.CanContentScroll="False">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                        </DockPanel>

                    </TabItem>

                    <TabItem x:Name="JvkTab" Header="ЖВК">
