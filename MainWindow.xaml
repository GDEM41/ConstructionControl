                    </Border>

                    <TabControl x:Name="MainTabs"
             Grid.Row="1"
             BorderThickness="0"
             Style="{StaticResource MainTabControlStyle}"
             ItemContainerStyle="{StaticResource HiddenPinnedTabItemStyle}"
             SelectionChanged="TabControl_SelectionChanged">


                    <!-- ===== СВОДНАЯ ===== -->
                        <TabItem x:Name="SummaryTab" Header="Сводка">
                            <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Margin="0,0,0,10">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0"
                                          Margin="0,0,0,10"
                                          VerticalAlignment="Top">
                                            <ToggleButton x:Name="SummaryFilterButton"
                                                      Style="{StaticResource SummaryFilterToggle}"
                                                      HorizontalContentAlignment="Left">
                                                <StackPanel>
                                                    <TextBlock Text="Фильтр типов" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock x:Name="SummaryFilterSubtitle" Text="Нет доступных типов" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>

                                                </StackPanel>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=SummaryFilterButton}" IsOpen="{Binding IsChecked, ElementName=SummaryFilterButton}" PopupAnimation="Fade" AllowsTransparency="True" StaysOpen="False">
                                                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource StrokeBrush}" BorderThickness="1" CornerRadius="10" Padding="12" MinWidth="260">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18"/>
                                                    </Border.Effect>
                                                    <StackPanel>
                                                        <TextBlock Text="Показывать в сводке" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"/>
                                                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                            <StackPanel x:Name="SummaryTypeFilterPanel"/>
                                                        </ScrollViewer>
                                                        <Separator Margin="0,8,0,8"/>
                                                        <TextBlock Text="Подтип" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"/>
                                                        <StackPanel x:Name="SummarySubTypeFilterPanel"/>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                    </Grid>
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SurfaceAltBrush}"
                                            BorderBrush="{DynamicResource StrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="12,12,2,2"
                                            Margin="0,0,0,10"
                                            VerticalAlignment="Top">
                                        <WrapPanel VerticalAlignment="Top">
                                            <Button Content="Потребность по отметкам"
                                                    MinWidth="192"
                                                    Style="{StaticResource ModernSummaryActionButton}"
                                                    Click="OpenDemandEditor_Click"/>
                                            <Button Content="Дозаказать"
                                                    MinWidth="148"
                                                    Style="{StaticResource ModernSummaryActionButton}"
                                                    Click="OpenReorderWindow_Click"/>
                                            <Button Content="Дефициты/излишки"
                                                    MinWidth="176"
                                                    Style="{StaticResource SummaryToolbarSecondaryButton}"
                                                    Click="OpenSummaryBalanceWindow_Click"/>
                                            <Button Content="Сравнение"
                                                    MinWidth="142"
                                                    Style="{StaticResource SummaryToolbarSecondaryButton}"
                                                    Click="OpenSummaryComparisonWindow_Click"/>
                                            <CheckBox x:Name="SummaryMountedModeSwitch"
                                                      Content="Режим монтажа"
