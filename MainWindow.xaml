                                                              Content="Бригадир"
                                                              Style="{StaticResource TimesheetFlagCheckBox}"/>
                                                </WrapPanel>
                                            </Border>

                                            <Border Grid.Column="2"
                                                    Style="{StaticResource TimesheetToolbarSectionBorder}">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                              VerticalScrollBarVisibility="Disabled"
                                                              CanContentScroll="False">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Style="{StaticResource TimesheetToolbarPrimaryButton}"
                                                                Click="AddTimesheetPerson_Click">➕ Добавить</Button>
                                                        <Button Style="{StaticResource TimesheetToolbarSecondaryButton}"
                                                                Click="DeleteTimesheetPerson_Click">🗑 Удалить</Button>
                                                        <Button Style="{StaticResource TimesheetToolbarSecondaryButton}"
                                                                Click="EditSelectedDayComment_Click">💬 Комментарий</Button>
                                                        <Button Style="{StaticResource TimesheetToolbarSecondaryButton}"
                                                                Margin="0"
                                                                Click="ToggleSelectedDayDocument_Click">📄 Документ</Button>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                <DataGrid x:Name="TimesheetGrid"
                                      Grid.Row="0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      GridLinesVisibility="All"
                                      VerticalGridLinesBrush="{DynamicResource DividerBrush}"
                                      HorizontalGridLinesBrush="{DynamicResource DividerBrush}"
                                      ColumnWidth="Auto"
                                      HeadersVisibility="Column"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.CanContentScroll="True"
                                      BeginningEdit="TimesheetGrid_BeginningEdit"
                                      CellEditEnding="TimesheetGrid_CellEditEnding"
                                      RowEditEnding="TimesheetGrid_RowEditEnding"
                                      LoadingRow="TimesheetGrid_LoadingRow"
                                      AutoGeneratingColumn="TimesheetGrid_AutoGeneratingColumn"
                                      SelectionUnit="Cell"
                                      SelectionMode="Extended"
                                      SelectedCellsChanged="TimesheetGrid_SelectedCellsChanged"
                                      PreviewKeyDown="TimesheetGrid_PreviewKeyDown"/>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="ProductionTab" Header="ПР">
