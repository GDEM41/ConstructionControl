                                            <Border Grid.Column="0"
                                                    Style="{StaticResource TimesheetToolbarSectionBorder}">
                                                <WrapPanel>
                                                    <TextBox x:Name="TimesheetFullNameTextBox"
                                                             Width="260"
                                                             Style="{StaticResource TimesheetToolbarFieldTextBox}"
