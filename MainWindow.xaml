                    <MenuItem Header="Показать журнал изменений" Click="ShowChangeLog_Click"/>
                    <MenuItem Header="Восстановить из автосохранения" Click="RestoreFromAutoBackup_Click"/>
                    <MenuItem Header="Создать пакет восстановления" Click="CreateRecoveryPackage_Click"/>
                    <MenuItem Header="Восстановить из пакета восстановления" Click="RestoreFromRecoveryPackage_Click"/>
                </MenuItem>
                <MenuItem Header="Справочники" Click="ReferenceCatalogs_Click"/>
                <MenuItem Header="Настройки">
                    <MenuItem Header="Параметры интерфейса" Click="AppSettings_Click"/>
