                            <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,4,0,6">

                                <Button x:Name="MergeButton"
                    Style="{StaticResource SecondaryButton}"
                    Content="⇆ Объединить"
                    Margin="0,0,10,0"
