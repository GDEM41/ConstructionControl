                        <MenuItem Header="Пресеты колонок">
                            <MenuItem Header="Сохранить текущий..." Click="SaveCurrentGridPreset_Click"/>
                            <MenuItem Header="Применить..." Click="ApplyCurrentGridPreset_Click"/>
                            <MenuItem Header="Удалить..." Click="DeleteCurrentGridPreset_Click"/>
                        </MenuItem>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Менеджер колонок" Click="OpenColumnManager_Click" InputGestureText="Ctrl+Shift+M"/>
                    <MenuItem Header="Глобальный поиск" Click="OpenGlobalSearch_Click" InputGestureText="Ctrl+F"/>
                    <MenuItem Header="Командная палитра" Click="OpenCommandPalette_Click"/>
                </MenuItem>
        </Menu>

        <!-- ================= TOOLBAR ================= -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="0,0,0,1"
                Padding="6">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ToolBar Grid.Column="0" Background="Transparent">

                <Button Style="{StaticResource IconButton}"
                        ToolTip="Сохранить"
                        Click="SaveButton_Click">
                    💾
                </Button>

                <Button Style="{StaticResource IconButton}"
                        ToolTip="Сохранить как"
                        Click="SaveAs_Click">
                    💾+
                </Button>

                <ToggleButton Style="{StaticResource IconToggle}"
              ToolTip="Блокировка"
              IsChecked="True"
              Checked="LockToggle_Checked"
              Unchecked="LockToggle_Unchecked">
                    🔒
                </ToggleButton>



                <Separator Margin="6,0"/>

                <Button x:Name="UndoButton"
        Style="{StaticResource IconButton}"
        Click="Undo_Click"
        IsEnabled="False">
                    ↩

                </Button>

                <Button x:Name="RedoButton"
        Style="{StaticResource IconButton}"
        Click="Redo_Click"
        IsEnabled="False">
                    ↪
                </Button>
                
                    <Separator Margin="6,0"/>
                
                    <Button Style="{StaticResource IconButton}"
                        ToolTip="Обновить"
                        Click="RefreshButton_Click">⟳</Button>
                    <Separator Margin="10,0"/>

                </ToolBar>

                <StackPanel Grid.Column="1"
