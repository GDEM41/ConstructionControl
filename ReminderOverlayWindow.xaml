<Window x:Class="ConstructionControl.ReminderOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Напоминания"
        Width="500"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="ReminderPrimaryActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="132"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ReminderSecondaryActionButton" TargetType="Button" BasedOn="{StaticResource AppSecondaryButton}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Padding="12"
            CornerRadius="12"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            MaxWidth="500"
            Effect="{StaticResource SoftShadowEffect}">
        <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Напоминания"
                           Foreground="{StaticResource TextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button x:Name="SnoozeButton"
                            Style="{StaticResource ReminderPrimaryActionButton}"
                            Height="30"
                            Padding="10,0"
                            Margin="0,0,8,0"
                            Click="SnoozeButton_Click"
                            Content="Отложить"/>
                    <Button x:Name="ToggleDetailsButton"
                            Style="{StaticResource ReminderSecondaryActionButton}"
                            Height="30"
                            Padding="10,0"
                            Click="ToggleDetailsButton_Click"
                            Content="Скрыть"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="StateText"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"/>

            <ItemsControl x:Name="SectionsHost"
                          Margin="0,10,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource StrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Header}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</Window>
